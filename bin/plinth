#!/usr/bin/env bash
# Plinth CLI v4.5.0 — scaffold and update projects from a pinned Plinth release.
#
#   plinth init   <project-path>  Bootstrap: create per-project files (only where
#                                 absent) + copy shared files. Idempotent.
#   plinth watch  <project-path>  Live session dashboard (task, stage pipeline,
#                                 tokens, burn, review/gate state). --once for a
#                                 single frame.
#   plinth update <project-path>  Propagate a Plinth version to an existing project:
#                                 refresh shared files (always overwritten), backfill
#                                 any per-project files new to this Plinth version
#                                 (created only if absent). Your per-project files are
#                                 not rewritten, with TWO managed exceptions:
#                                 .plinth/protected-paths gets new plinth-managed
#                                 security patterns appended (your lines preserved), and
#                                 a legacy root NEEDS-HUMAN.md is migrated into .plinth/
#                                 (warns instead of clobbering if both exist).
#                                 Reports the version transition. Refuses to run on a
#                                 directory that isn't already a Plinth project.
#   plinth goal   <project-path>  Drop a GOAL.md draft (auto-research mode) if absent.
#
# Operates from the Plinth checkout it lives in. To adopt a new Plinth version:
# `git -C <plinth> pull` (or checkout a tag), then `plinth update <project>`.
set -euo pipefail

# Resolve symlinks so PLINTH_ROOT is the real checkout, not the symlink's dir.
# (A naive dirname "$BASH_SOURCE" resolves to /usr/local when invoked via the
#  /usr/local/bin/plinth symlink, breaking every subcommand. Do not simplify.)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"  # relative link -> absolute
done
PLINTH_ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
PLINTH_VERSION="$(cat "$PLINTH_ROOT/VERSION" 2>/dev/null || echo "unknown")"

usage() { echo "Usage: plinth {init|update|goal|watch|statusline|queue} <project-path> [--once]
       plinth smoke <project-path> -- <command...>   (run + write execution receipt)
       plinth queue <project-path>                   (full NEEDS-HUMAN queue, untruncated)
       plinth advise [--impactful] \"<question>\"       (consult a stronger model, read-only; runs in CWD)
       plinth hookprobe <grok|codex>                 (does this CLI EXECUTE wired .claude hooks? one model call)"; exit 1; }
[ $# -ge 1 ] || usage
cmd="$1"; target="${2:-}"; opt="${3:-}"
if [ "$cmd" = "statusline" ] || [ "$cmd" = "advise" ] || [ "$cmd" = "hookprobe" ]; then
  :  # statusline: project path optional (falls back to statusLine JSON on stdin).
     # advise: operates on the CWD; its args are the question, not a project path.
     # hookprobe: probes a vendor CLI in a scratch repo; its arg is a vendor, not a path.
elif [ -z "$target" ]; then
  usage
elif [ ! -d "$target" ]; then
  echo "No such directory: $target"; exit 1
fi

# Portable in-place edit (macOS + Linux): sed to a temp file in the SAME dir (so mv is atomic), then
# move. The temp path is created UNPREDICTABLY via mktemp (O_EXCL) — never a predictable sibling like
# `${f}.plinth-tmp` a repo could precreate as a symlink/hardlink to an external target and be written
# through before the mv (path-escape / clobber).
edit_file() {  # edit_file <file> <sed-expr>...
  local f="$1"; shift
  # Read the ORIGINAL mode FIRST and fail closed if it can't be established: mktemp creates 0600,
  # so a swallowed chmod would move a 0600 (group/other-UNREADABLE) file into place — the exact
  # regression this preservation exists to prevent (e.g. a generated ci.yml unreadable until git
  # recreates it). GNU (-c) first; BSD (-f) fallback. Must be octal digits.
  local mode; mode="$(stat -c '%a' "$f" 2>/dev/null || stat -f '%Lp' "$f" 2>/dev/null)"
  case "$mode" in ''|*[!0-7]*) echo "edit_file: cannot determine the mode of $f (stat failed) — refusing to rewrite it (fail closed)" >&2; exit 1 ;; esac
  local tmp; tmp="$(mktemp "$(dirname "$f")/.plinth-tmp.XXXXXX")" || { echo "edit_file: mktemp failed for $f" >&2; exit 1; }
  chmod "$mode" "$tmp" || { rm -f "$tmp"; echo "edit_file: could not apply mode $mode to the temp for $f — refusing (fail closed, would leave it 0600/unreadable)" >&2; exit 1; }
  sed "$@" "$f" > "$tmp" && mv "$tmp" "$f" || { rm -f "$tmp"; echo "edit_file: failed to rewrite $f" >&2; exit 1; }
}

# NEEDS-HUMAN queue path — canonical is .plinth/NEEDS-HUMAN.md; tolerate a legacy
# root copy (some projects kept it there) so the queue and dashboard still find it.
# `plinth update` migrates a root copy into .plinth/ (see migrate_needs_human).
needs_human_file() {  # <dir> -> active NEEDS-HUMAN.md path (canonical preferred)
  if [ -f "$1/.plinth/NEEDS-HUMAN.md" ]; then echo "$1/.plinth/NEEDS-HUMAN.md"
  elif [ -f "$1/NEEDS-HUMAN.md" ]; then echo "$1/NEEDS-HUMAN.md"
  else echo "$1/.plinth/NEEDS-HUMAN.md"; fi
}
migrate_needs_human() {  # move a legacy root NEEDS-HUMAN.md into .plinth/ (canonical)
  local root="$target/NEEDS-HUMAN.md" canon="$target/.plinth/NEEDS-HUMAN.md"
  [ -f "$root" ] || return 0
  if [ -f "$canon" ]; then
    echo "  NOTE: NEEDS-HUMAN.md exists at BOTH repo root and .plinth/ — canonical is"
    echo "        .plinth/; merge the root copy in by hand and delete it."
  else
    mkdir -p "$target/.plinth"; mv "$root" "$canon"
    echo "  migrated: NEEDS-HUMAN.md -> .plinth/NEEDS-HUMAN.md (canonical location)"
  fi
}

# Detect the GitHub owner for ci.yml injection. Chain: target repo's origin ->
# this Plinth checkout's origin -> git config github.user -> empty (warn).
# Parses both git@github.com:owner/repo.git and https://github.com/owner/repo(.git).
detect_owner() {
  local url owner
  for repo in "$target" "$PLINTH_ROOT"; do
    url="$(git -C "$repo" remote get-url origin 2>/dev/null || true)"
    if [ -n "$url" ]; then
      owner="$(printf '%s' "$url" | sed -E 's#^(git@[^:]+:|https?://[^/]+/)([^/]+)/.*#\2#')"
      if [ -n "$owner" ] && [ "$owner" != "$url" ]; then printf '%s' "$owner"; return 0; fi
    fi
  done
  owner="$(git config github.user 2>/dev/null || true)"
  [ -n "$owner" ] && { printf '%s' "$owner"; return 0; }
  printf ''
}

# Materialize the DRIVER contract shell into BOTH CLAUDE.md and AGENTS.md
# (byte-identical). Whichever a vendor auto-loads delivers the driver role:
# Claude reads CLAUDE.md (and expands the @import); codex reads AGENTS.md; grok
# reads both. AGENTS.md was ALWAYS a pinned copy (reviewer contract pre-v4.4.0,
# driver shell now) — safe to (re)generate unconditionally. CLAUDE.md was
# historically per-project (held user "Project-specific notes"), so only
# (re)generate it when absent or already a stock shell; otherwise PRESERVE it and
# tell the human to move notes into .plinth/DRIVER-project.md (no auto-extraction —
# marker-parsing a user-edited file is a known bug class).
DRIVER_SHELL_MARKER="Plinth driver shell (version-pinned)"
# True if $1 is the pre-v4.4 STOCK driver CLAUDE.md: the WHOLE file equals the retired
# templates/CLAUDE.md verbatim (whitespace-normalized: per-line trim, blank lines
# dropped). Whole-file — not marker/section — comparison, because custom content can
# live ANYWHERE (a rule added above the notes heading, notes inside the placeholder
# comment); only a byte-honest match proves there is nothing to lose, so `update` may
# regenerate it as the new shell (the migration the CHANGELOG promises). ANY deviation
# — including an older template revision we do not recognize — is treated as custom and
# preserved with the migration NOTE: a false "custom" costs a 30-second manual step, a
# false "stock" destroys user content.
is_stock_old_claude() {
  local f="$1" norm ref
  norm="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' "$f" 2>/dev/null | grep -v '^$' || true)"
  ref="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' <<'OLDSTOCK' | grep -v '^$'
# CLAUDE.md

You are the implementer for this repository. The canonical spec (see `spec_path` in `.plinth/config`; default `SPEC.md`) is the source of truth —
read it before implementing. Model and orchestration guidance: `.plinth/MODELS.md`.

@.plinth/plinth-rules.md

## Precedence — these rules override defaults
Where this file or the plinth rules conflict with harness defaults, output
styles, or personal/global preferences, PLINTH RULES WIN. Standing exceptions
you must apply without being asked:
- COMMIT your work on feature branches as part of the loop — do not wait for
  permission. Verdicts bind to commit SHAs and the Stop gate requires an
  APPROVED review at HEAD; a driver that waits to be asked deadlocks itself.
  (Opening the PR follows review; pushing follows the rules, not impulse.)
- Rule 10 evidence — pasted runner output — overrides any brevity or style
  preference, always.
- If a personal or global instruction conflicts with the plinth rules, follow
  the plinth rules and SAY you did; never silently blend the two.

## Project-specific notes
<!-- Anything unique to THIS project: domain constraints, hard "never do" rules,
     stack quirks. Shared Plinth rules import above; this section is yours and is
     never overwritten by `plinth update`. -->
OLDSTOCK
)"
  [ -n "$norm" ] && [ "$norm" = "$ref" ]
}
materialize_driver_shell() {
  cp "$PLINTH_ROOT/shared/driver-shell.md" "$target/AGENTS.md"
  local c="$target/CLAUDE.md"
  if [ ! -f "$c" ] || grep -qF "$DRIVER_SHELL_MARKER" "$c" 2>/dev/null || is_stock_old_claude "$c"; then
    cp "$PLINTH_ROOT/shared/driver-shell.md" "$c"   # absent, already-shell, or stock old -> (re)generate
  else
    echo "  NOTE: $c has CUSTOM content — NOT overwritten. The v4.4.0 driver contract"
    echo "        is a pinned shell (CLAUDE.md + AGENTS.md, regenerated) plus"
    echo "        .plinth/DRIVER-project.md for your notes. Move your"
    echo "        '## Project-specific notes' into .plinth/DRIVER-project.md, then delete"
    echo "        CLAUDE.md and re-run 'plinth update' to regenerate the shell."
  fi
}

# The two lane-agent filenames are RESERVED for version-pinned Plinth tooling (protected-path +
# HARNESS-classified by path). Refresh the pinned copy freely, but if a NON-Plinth file already
# occupies that exact path (no pin marker = project-authored), do NOT clobber it and do NOT leave a
# half-managed state (a preserved file would still get frozen/misclassified) — fail LOUD and abort so
# the user resolves it. Non-destructive: their file is untouched.
cp_lane_agent() {  # <src> <dst> — belt: preflight_reserved_lanes should have caught a collision first
  local src="$1" dst="$2" marker='Plinth implementer lane (version-pinned)'
  if [ -f "$dst" ] && ! grep -qF "$marker" "$dst" 2>/dev/null; then
    echo "ERROR: $dst exists and is NOT a Plinth lane agent. That filename is RESERVED for the Plinth" >&2
    echo "       implementer lane (version-pinned tooling). Rename or move your file, then re-run —" >&2
    echo "       refusing to overwrite it or leave it half-managed (protected/frozen but project-owned)." >&2
    exit 1
  fi
  cp "$src" "$dst"
}
# Preflight the reserved lane-agent paths BEFORE any file is written, so a collision aborts with the
# repo UNTOUCHED — never a partial scaffold (protected-paths / settings.json / a new review.sh already
# installed while the project's colliding agent stays behind, frozen or misclassified).
# A managed FILE target must be ABSENT or a true regular file — reject a symlink (would clobber its
# external target), a directory (cp would copy INTO it, partial scaffold), or a FIFO/socket/device
# (cp would hang/misbehave). Used before any managed-file write.
reject_nonregular_file() {  # <path>
  if [ -L "$1" ]; then echo "ERROR: $1 is a symlink — refusing to write through it." >&2; exit 1; fi
  if [ -e "$1" ] && [ ! -f "$1" ]; then echo "ERROR: $1 is present but not a regular file (a directory or special file) — refusing." >&2; exit 1; fi
  # A HARDLINK (nlink > 1) shares its inode with a file elsewhere; cp/redirection would truncate that
  # shared inode and clobber the external target. Refuse rather than write through it.
  if [ -f "$1" ]; then
    # GNU (-c) first; BSD stat rejects -c and falls through to -f. Reverse order is WRONG: GNU
    # `stat -f '%l'` succeeds with filesystem status (not nlink), so the `||` never falls through.
    local n; n="$(stat -c '%h' "$1" 2>/dev/null || stat -f '%l' "$1" 2>/dev/null)"
    # FAIL CLOSED if the link count can't be determined (both stat forms failed / non-numeric):
    # defaulting to 1 would let a copy proceed and clobber an external hardlink (data loss).
    case "$n" in ''|*[!0-9]*) echo "ERROR: cannot determine link count of $1 (stat failed) — refusing to touch it (fail closed)." >&2; exit 1 ;; esac
    if [ "$n" -gt 1 ]; then echo "ERROR: $1 is a hardlink (nlink=$n) — refusing to overwrite a shared inode (would clobber the other link)." >&2; exit 1; fi
  fi
}
preflight_reserved_lanes() {
  local marker='Plinth implementer lane (version-pinned)' a dst parent="$target/.claude/agents" d f mansym
  # SYMLINK-ESCAPE CLASS — closed once, up front, before ANY write: init/update write many files and
  # dirs under the managed trees, and a symlink anywhere in that ancestry (a managed dir, an
  # intermediate, or a file leaf) would let a write follow it and clobber a target OUTSIDE the
  # workspace, or make a policy read return the wrong bytes. Refuse rather than write through any.
  # (1) managed DIRECTORIES + intermediates: never a symlink, never a non-directory.
  for d in .claude .claude/agents .claude/hooks .plinth .plinth/session .github .github/workflows; do
    if [ -L "$target/$d" ]; then
      echo "ERROR: $target/$d is a symlink — refusing to write through it (could escape the workspace)." >&2
      exit 1
    fi
    if [ -e "$target/$d" ] && [ ! -d "$target/$d" ]; then
      echo "ERROR: $target/$d exists but is not a directory — refusing to touch this repo until it is resolved." >&2
      exit 1
    fi
  done
  # (2) every managed FILE leaf that is unconditionally (re)written must be ABSENT or a real regular
  #     file — never a symlink, directory, FIFO, or device (else cp escapes / copies into a dir / hangs).
  #     Checked per Plinth-OWNED path only (NOT a whole-tree sweep) — a project's own .claude/agents/*
  #     or unrelated .github/* symlink must NOT block init/update.
  for f in \
    .plinth/plinth-rules.md .plinth/MODELS.md .plinth/review.sh .plinth/risk-classify.sh \
    .plinth/lane-guard.sh .plinth/review-schema.json .plinth/reviewer.md .plinth/protected-paths \
    .plinth/config .plinth/AGENTS-project.md .plinth/DRIVER-project.md \
    .claude/hooks/guard.sh .claude/hooks/session-start.sh .claude/hooks/review-gate.sh \
    .claude/hooks/pulse.sh .claude/settings.json .github/workflows/ci.yml .github/workflows/smoke.yml \
    SPEC.md .gitignore AGENTS.md CLAUDE.md .plinth-version; do
    reject_nonregular_file "$target/$f"
  done
  # (3) the NEEDS-HUMAN queue MIGRATION targets. update mv's a legacy root NEEDS-HUMAN.md into
  #     .plinth/NEEDS-HUMAN.md (migrate_needs_human). If the canonical DESTINATION is a directory,
  #     `mv` nests the queue inside it; if it (or the legacy SOURCE) is a symlink, `mv`/later reads
  #     follow it and move/expose the queue OUTSIDE the workspace. Reject any non-regular node at
  #     BOTH before update writes anything (absent is fine — the common case).
  for f in .plinth/NEEDS-HUMAN.md NEEDS-HUMAN.md; do
    reject_nonregular_file "$target/$f"
  done
  # (4) the two RESERVED lane-agent names.
  for a in grok-implementer codex-implementer; do
    dst="$parent/$a.md"
    # First reject any symlink / directory / FIFO / device / HARDLINK at the reserved path — same
    # write-through/escape guard as every other managed leaf (cp_lane_agent would otherwise clobber a
    # hardlink's external inode).
    reject_nonregular_file "$dst"
    # Now dst is ABSENT or a true regular file. A regular file WITHOUT the pin marker is project-
    # authored content occupying the RESERVED lane name — a collision; abort before any write.
    if [ -f "$dst" ] && ! grep -qF "$marker" "$dst" 2>/dev/null; then
      echo "ERROR: $dst is present but is not the Plinth lane agent (project-authored content). That" >&2
      echo "       path is RESERVED for the version-pinned Plinth implementer lane. Remove or rename" >&2
      echo "       it, then re-run — refusing to touch this repo." >&2
      exit 1
    fi
  done
}

# SHARED (version-pinned, overwritten on update):
copy_shared() {
  mkdir -p "$target/.plinth" "$target/.claude/hooks" "$target/.claude/agents"
  cp "$PLINTH_ROOT/shared/plinth-rules.md"        "$target/.plinth/plinth-rules.md"
  cp "$PLINTH_ROOT/shared/MODELS.md"              "$target/.plinth/MODELS.md"
  cp "$PLINTH_ROOT/shared/.plinth/review.sh"      "$target/.plinth/review.sh"
  cp "$PLINTH_ROOT/shared/.plinth/risk-classify.sh" "$target/.plinth/risk-classify.sh"
  cp "$PLINTH_ROOT/shared/.plinth/lane-guard.sh"  "$target/.plinth/lane-guard.sh"
  cp "$PLINTH_ROOT/shared/.plinth/review-schema.json" "$target/.plinth/review-schema.json"
  cp "$PLINTH_ROOT/shared/.claude/hooks/guard.sh" "$target/.claude/hooks/guard.sh"
  cp "$PLINTH_ROOT/shared/.claude/hooks/session-start.sh" "$target/.claude/hooks/session-start.sh"
  cp "$PLINTH_ROOT/shared/.claude/hooks/review-gate.sh"   "$target/.claude/hooks/review-gate.sh"
  cp "$PLINTH_ROOT/shared/.claude/hooks/pulse.sh"         "$target/.claude/hooks/pulse.sh"
  # Lane agents live in .claude/agents/ — a namespace a project may ALSO use. The two lane filenames
  # are RESERVED: preflight_reserved_lanes() already aborted (repo untouched) if a non-Plinth file
  # occupied either path, so here we just refresh the pinned copy (cp_lane_agent re-checks as a belt).
  cp_lane_agent "$PLINTH_ROOT/shared/.claude/agents/grok-implementer.md"  "$target/.claude/agents/grok-implementer.md"
  cp_lane_agent "$PLINTH_ROOT/shared/.claude/agents/codex-implementer.md" "$target/.claude/agents/codex-implementer.md"
  cp "$PLINTH_ROOT/shared/reviewer.md"           "$target/.plinth/reviewer.md"
  materialize_driver_shell
  chmod +x "$target/.plinth/review.sh" "$target/.plinth/risk-classify.sh" "$target/.plinth/lane-guard.sh" \
           "$target/.claude/hooks/guard.sh" \
           "$target/.claude/hooks/session-start.sh" "$target/.claude/hooks/review-gate.sh" \
           "$target/.claude/hooks/pulse.sh"
  echo "$PLINTH_VERSION" > "$target/.plinth-version"
}

# GitHub preflight: verify the layers underneath the gates actually exist.
# Automates what is safe (local git init), asks consent for what is outward
# (creating a GitHub repo), and only REPORTS on branch protection — required-
# check names exist only after the first CI run; configuring them blind can
# block merging forever behind checks that never report.
github_preflight() {
  if ! git -C "$target" rev-parse --git-dir >/dev/null 2>&1; then
    git -C "$target" init -b main >/dev/null 2>&1 || git -C "$target" init >/dev/null 2>&1
    echo "  git:           initialized repository — Plinth's review, gates, and dashboard were inert without it"
  fi
  if ! git -C "$target" rev-parse -q --verify HEAD >/dev/null 2>&1; then
    echo "  git:           NO COMMITS yet — commit the scaffold + spec BEFORE starting a"
    echo "                 driver. Verdicts and gates bind to commits; on an unborn branch"
    echo "                 the review loop cannot run."
  fi
  command -v gh >/dev/null 2>&1 || { echo "  github:        gh CLI not found — install it to verify/create the remote and check protection"; return 0; }
  gh auth status >/dev/null 2>&1 || { echo "  github:        gh not authenticated (run: gh auth login) — skipping remote/protection checks"; return 0; }

  local url name slug defb out
  url="$(git -C "$target" remote get-url origin 2>/dev/null || true)"
  if [ -z "$url" ]; then
    name="$(basename "$target")"
    if [ -t 0 ]; then
      printf '  github:        no origin remote. Create GitHub repo "%s" now? [y/N] ' "$name"
      read -r ans || ans=""
      if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
        printf '  visibility:    public gets branch protection on the free plan; private needs Pro. [public/private] (public): '
        read -r vis || vis=""
        [ "$vis" = "private" ] || vis="public"
        if (cd "$target" && gh repo create "$name" "--$vis" --source . --push); then
          echo "  github:        created and pushed ($vis)"
          url="$(git -C "$target" remote get-url origin 2>/dev/null || true)"
        else
          echo "  github:        creation failed — run manually: gh repo create $name --$vis --source \"$target\" --push"
          return 0
        fi
      else
        echo "  github:        skipped. When ready: gh repo create $name --public --source \"$target\" --push"
        return 0
      fi
    else
      echo "  github:        no origin remote. When ready: gh repo create $name --public --source \"$target\" --push"
      return 0
    fi
  fi

  slug="$(printf '%s' "$url" | sed -E 's#^(git@[^:]+:|https?://[^/]+/)##; s#\.git$##')"
  defb="$(gh api "repos/$slug" -q .default_branch 2>/dev/null || echo main)"
  if out="$(gh api "repos/$slug/branches/$defb/protection" 2>&1)"; then
    # "configured" alone is not the guarantee — verify the required CONTEXTS actually
    # cover the floor and checks jobs; protection with the wrong (or no) contexts
    # leaves merges ungated while the preflight reads as healthy.
    ctxs="$(printf '%s' "$out" | jq -r '.required_status_checks.contexts[]?' 2>/dev/null || true)"
    # The floor is FOUR independent jobs (secrets, sast, dependencies/osv-scan, harness) —
    # each needs its own required context; one present floor job does not gate the others.
    # Contexts are matched by JOB NAME (grep -xF, exact) — GitHub does not prefix required-check
    # contexts with the workflow name; the caller jobs are the scaffold's `floor` and `checks`.
    miss=""
    # GitHub required-check contexts are JOB names, NOT workflow-name-prefixed labels: a direct job
    # is "<job>"; a reusable-workflow job is "<caller-job> / <reusable-job>". The scaffold's caller
    # jobs are `floor` and `checks`, so the expected contexts are "floor / secrets", "floor / sast",
    # "floor / dependencies / osv-scan", "floor / harness", and "checks / <job>" (or "checks" direct).
    # Fetch actual check-runs ONCE and validate EVERY configured floor+checks context against them:
    # a context that is required but names no real job (jobs removed/renamed) is a ghost gate.
    runs="$(gh api --paginate "repos/$slug/commits/$defb/check-runs" -q '.check_runs[].name' 2>/dev/null || true)"
    ckctx="$(printf '%s\n' "$ctxs" | grep -E "^checks( / [^/]+)?\$" || true)"
    # required-set membership (grep -xF) first:
    fmiss=""
    for want in "floor / secrets" "floor / sast" "floor / dependencies / osv-scan" "floor / harness"; do
      printf '%s\n' "$ctxs" | grep -qxF "$want" || fmiss="${fmiss:+$fmiss }$want"
    done
    [ -z "$fmiss" ] || for w in $fmiss; do case "$w" in *secrets) miss="${miss:+$miss, }floor/secrets";; *sast) miss="${miss:+$miss, }floor/sast";; *harness) miss="${miss:+$miss, }floor/harness";; *osv-scan) miss="${miss:+$miss, }floor/dependencies/osv-scan";; esac; done
    [ -n "$ckctx" ] || miss="${miss:+$miss, }checks"
    # then cross-check EVERY present floor/checks context against actual check runs (fail closed on
    # no data): a required context not among real check runs is a ghost gate that never reports.
    present="$(printf '%s\n' "$ctxs" | grep -E "^floor / (secrets|sast|harness|dependencies / osv-scan)\$|^checks( / [^/]+)?\$" || true)"
    if [ -n "$present" ]; then
      if [ -z "$runs" ]; then
        miss="${miss:+$miss, }UNVERIFIED: no check-run data on $defb — cannot confirm the required contexts name real jobs; re-run after the first PR"
      else
        ghost=""
        while IFS= read -r c; do [ -n "$c" ] || continue; printf '%s\n' "$runs" | grep -qxF "$c" || ghost="${ghost:+$ghost; }$c"; done <<GHOSTEOF
$present
GHOSTEOF
        [ -z "$ghost" ] || miss="${miss:+$miss, }required context(s) not among actual check runs: $ghost"
      fi
    fi
    if [ -z "$ctxs" ]; then
      echo "  protection:    configured on $defb — but NO required status checks are set, so"
      echo "                 floor/checks do NOT gate merges. Add them (Settings -> Branches)."
    elif [ -n "$miss" ]; then
      echo "  protection:    configured on $defb — but required contexts are MISSING: $miss."
      echo "                 Present: $(printf '%s' "$ctxs" | tr '\n' ' '). Absent jobs do not gate merges."
    else
      echo "  protection:    configured on $defb (required: $(printf '%s' "$ctxs" | tr '\n' ' '))"
    fi
  elif printf '%s' "$out" | grep -q "Upgrade to GitHub Pro"; then
    echo "  protection:    IMPOSSIBLE on this plan (private repo, GitHub Free) — floor/checks are"
    echo "                 NOT required to merge. Make the repo public or upgrade to Pro."
  elif printf '%s' "$out" | grep -qi "not protected"; then
    echo "  protection:    available but NOT configured on $defb. After the first PR shows the"
    echo "                 check names, require them: repo Settings -> Branches -> protect $defb."
  else
    echo "  protection:    could not determine: $(printf '%s' "$out" | tr '\n' ' ' | head -c 90)"
  fi
}

# settings.json is per-project (never overwritten), so new hook wiring cannot
# propagate silently. Warn when the shared hooks exist but aren't wired.
# protected-paths is per-project (never overwritten), so security-critical
# patterns plinth ships in newer versions do not reach upgraded projects on
# their own. Append any missing plinth-managed patterns (idempotent); user-added
# lines are left untouched.
ensure_protected_paths() {
  local f="$target/.plinth/protected-paths"
  # A symlinked/non-regular policy file must NOT be appended THROUGH — that would rewrite an external
  # target and, read back via `git show base:`, silently narrow protection. Belt:
  # preflight_reserved_lanes already refuses it, but ensure runs standalone (init/update both call it).
  reject_nonregular_file "$f"
  [ -f "$f" ] || return 0
  local added=0 line
  # If the file doesn't end in a newline, appending would concatenate the first
  # managed pattern onto the user's last line, corrupting BOTH. Fix it first.
  [ -s "$f" ] && [ -n "$(tail -c1 "$f" 2>/dev/null)" ] && printf '\n' >> "$f"
  local sfx
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    # Dedup by PATH SUFFIX, not whole line. A project may protect the same path
    # with DIFFERENT anchoring — the Plinth-on-plinth repo uses (^|plinth/) so its
    # patterns match the INSTALLED copies but NOT the editable shared/ sources.
    # Appending our canonical (^|/) form there would ALSO match shared/.plinth/*,
    # wrongly freezing the PRODUCT. "Covered" therefore means: some ACTIVE
    # (non-comment, non-blank) line, after stripping its leading anchor — a
    # (^|...) group or a bare ^ — EQUALS the suffix exactly. Equality, not
    # substring: an active-but-different pattern like (^|/)old-CLAUDE\.md$
    # CONTAINS the suffix CLAUDE\.md$ yet protects a different path, and must
    # not suppress backfilling the real protection. Comments are excluded too.
    sfx="${line#'(^|/)'}"
    grep -Ev '^[[:space:]]*(#|$)' "$f" 2>/dev/null \
      | sed -E -e 's/^\(\^\|[^)]*\)//' -e 's/^\^//' \
      | grep -qxF -- "$sfx" \
      || { printf '%s\n' "$line" >> "$f"; added=$((added + 1)); }
  done <<'PATTERNS'
(^|/)\.plinth/session/
(^|/)\.plinth/config$
(^|/)\.claude/hooks/
(^|/)\.claude/agents/grok-implementer\.md$
(^|/)\.claude/agents/codex-implementer\.md$
(^|/)\.claude/settings\.json$
(^|/)\.plinth/review\.sh$
(^|/)\.plinth/risk-classify\.sh$
(^|/)\.plinth/lane-guard\.sh$
(^|/)\.plinth/review-schema\.json$
(^|/)\.plinth/plinth-rules\.md$
(^|/)\.plinth/MODELS\.md$
(^|/)\.plinth/reviewer\.md$
(^|/)\.plinth/protected-paths$
(^|/)CLAUDE\.md$
(^|/)AGENTS\.md$
PATTERNS
  [ "$added" -gt 0 ] && echo "  protected-paths: added $added plinth-managed security pattern(s)"
  return 0
}

warn_missing_gate_wiring() {
  if ! grep -q 'review-gate.sh' "$target/.claude/settings.json" 2>/dev/null; then
    echo "NOTE: .claude/settings.json (yours, never overwritten) lacks the review-gate"
    echo "wiring — the review Stop gate is NOT enforced in this project. Add the"
    echo "SessionStart and Stop hook entries from CHANGELOG v3.7."
  fi
  if ! grep -q 'pulse.sh' "$target/.claude/settings.json" 2>/dev/null; then
    echo "NOTE: .claude/settings.json lacks pulse.sh wiring — under a CLAUDE driver"
    echo "'plinth watch' will run feedless (reduced frame: branch/verdict/queue only)."
    echo "Whether a grok/codex driver executes these hooks: run 'plinth hookprobe <vendor>'"
    echo "(grok 0.2.93 reported no execution (reproduce: plinth hookprobe grok) — feedless is"
    echo "expected there; a driver the probe shows INVOKING PostToolUse yet feedless needs"
    echo "investigating: broken wiring, or the hook gets no usable stdin/env — see the probe"
    echo "json-stdin flag). For Claude, see CHANGELOG v3.8."
  fi
}

# ci.yml is per-project and NEVER rewritten by Plinth (the operator owns it). But its
# reusable-workflow refs pin a Plinth release SHA, and an upgrade that bumps
# .plinth-version WITHOUT repinning leaves the project calling the OLD floor/checks —
# so new floor checks never run while branch protection stays green. update can't
# silently rewrite the operator's workflow, so it WARNS loudly with the exact repin
# command when the pinned SHA is stale (matches the branch-protection warning pattern).
warn_stale_reusable_refs() {
  [ -f "$target/.github/workflows/ci.yml" ] || return 0
  local psha; psha="$(git -C "$PLINTH_ROOT" rev-parse HEAD 2>/dev/null || true)"
  if [ -z "$psha" ]; then
    # Non-git install (archive): we cannot resolve the release SHA to compare, but update still
    # advanced .plinth-version and installed new tooling. Warn LOUDLY rather than silently skip —
    # the old reusable floor/checks may still be active (mirrors the non-git INIT fail-loud path).
    echo "NOTE: could not resolve the Plinth release commit (non-git install?), so update cannot"
    echo "verify .github/workflows/ci.yml's reusable floor/checks refs. If a ref pins an older"
    echo "release, that gate runs older Plinth tooling (and the NEW floor checks run only once the"
    echo "FLOOR ref is current) — repin the reusable ref(s) present to this release's commit SHA."
    return 0
  fi
  # Warn if EITHER ref is stale — floor and checks are independent gates, either can lag.
  local ci="$target/.github/workflows/ci.yml"
  # Tie the check to the GATING jobs (`floor:` / `checks:`), not any uses: line anywhere —
  # a current ref under a decoy non-gating job must not suppress the warning. Best-effort
  # (this is an advisory warning, not a gate): read the uses: line within each job block.
  local fref cref
  # Match the gating job key with OR without surrounding quotes (YAML permits `"floor":`/`'checks':`),
  # and end the block at the NEXT top-level key whether quoted or not (a quoted key starts with a
  # quote, not a letter — the old `[a-zA-Z]`-only terminator would read past it).
  fref="$(awk '/^  ['\''"]?floor['\''"]?:/{f=1;next} f&&/uses:/{print;exit} f&&/^  ['\''"a-zA-Z]/{exit}' "$ci" 2>/dev/null)"
  cref="$(awk '/^  ['\''"]?checks['\''"]?:/{f=1;next} f&&/uses:/{print;exit} f&&/^  ['\''"a-zA-Z]/{exit}' "$ci" 2>/dev/null)"
  # A `checks:` job with NO plinth-checks.yml reusable ref is an intentional custom/direct gate
  # (template-supported) — not a stale Plinth ref. Only judge staleness of the REUSABLE refs
  # actually present; a customized checks job is not "stale".
  local fstale=0 cstale=0
  # EXACT-TOKEN boundary: the char after the current SHA must TERMINATE the ref token — whitespace
  # (before a `# comment`), a quote (a QUOTED value), or EOL — never another ref-token char
  # (`[[:alnum:]._/-]`). Anchoring on "not a ref char" so `<current-sha>-old` (a DIFFERENT, longer
  # ref) is correctly seen as STALE, and a quoted current ref is NOT falsely flagged.
  printf '%s' "$fref" | grep -q 'plinth-floor\.yml@' && ! printf '%s' "$fref" | grep -qE "plinth-floor\.yml@${psha}([^[:alnum:]._/-]|\$)" && fstale=1
  printf '%s' "$cref" | grep -q 'plinth-checks\.yml@' && ! printf '%s' "$cref" | grep -qE "plinth-checks\.yml@${psha}([^[:alnum:]._/-]|\$)" && cstale=1
  [ "$fstale" = 0 ] && [ "$cstale" = 0 ] && return 0
  # Name exactly which REUSABLE ref is stale (a custom/direct job is not stale), and emit a sed
  # that only touches the stale one(s) — never instruct repinning a job that has no reusable ref.
  local which sedpat
  if [ "$fstale" = 1 ] && [ "$cstale" = 1 ]; then which="reusable floor and checks refs"; sedpat='plinth-(floor|checks)'
  elif [ "$fstale" = 1 ]; then which="reusable floor ref (checks is a custom/direct gate or already current)"; sedpat='plinth-floor'
  else which="reusable checks ref (floor is a custom/direct gate or already current)"; sedpat='plinth-checks'; fi
  echo "NOTE: .github/workflows/ci.yml (yours, never rewritten) pins the $which at an OLDER Plinth"
  echo "commit, so that gate runs an OLDER Plinth workflow (new floor checks — lane tooling bytes +"
  echo "executable mode — only run once the FLOOR ref is current). Repin the stale ref to this release:"
  # Match the ref token as the full set of valid git-ref characters (`[[:alnum:]._/-]+` — includes
  # `/` for refs like `release/v4`): it stops at the closing quote of a QUOTED `uses: "…@sha"` value,
  # at whitespace before a `# comment`, and at end-of-line — so the repin preserves the quote/comment
  # and stays valid YAML. (`[^[:space:]]+` would swallow a closing quote; a class EXCLUDING quotes
  # cannot contain a literal `'` without breaking the single-quoted sed expression this line emits.)
  # Shell-quote the paths with `printf %q` so a target path containing a space, quote, backtick, or
  # $() is a safe single shell token in the advertised command (not broken or injectable).
  local qci qbak
  qci="$(printf '%q' "$target/.github/workflows/ci.yml")"
  qbak="$(printf '%q' "$target/.github/workflows/ci.yml.bak")"
  echo "  sed -i.bak -E 's#(${sedpat}\.yml@)[[:alnum:]._/-]+#\1${psha}#g' \\"
  echo "    $qci && rm -f $qbak"
}

# PER-PROJECT (templates, copied once, never overwritten):
copy_templates_if_absent() {
  place() {  # place <template-rel-path> <dest-rel-path>
    # only-if-absent, but the "absent" test must fail loud on a non-regular/symlinked dest (a symlink
    # or dir/FIFO at SPEC.md/.gitignore/… would let cp escape, copy into a dir, or hang):
    reject_nonregular_file "$target/$2"
    if [ -f "$target/$2" ]; then
      echo "  kept (yours):  $2"
    else
      cp "$PLINTH_ROOT/templates/$1" "$target/$2"
      echo "  created:       $2"
    fi
  }
  mkdir -p "$target/.claude" "$target/.github/workflows" "$target/.plinth"
  # CLAUDE.md is no longer a per-project template — it is a pinned driver shell
  # materialized by copy_shared (materialize_driver_shell). Project-specific driver
  # notes live in .plinth/DRIVER-project.md instead.
  place SPEC.md SPEC.md
  place .gitignore .gitignore
  place .claude/settings.json .claude/settings.json
  place AGENTS-project.md .plinth/AGENTS-project.md
  place DRIVER-project.md .plinth/DRIVER-project.md
  if [ -f "$target/.plinth/protected-paths" ]; then
    echo "  kept (yours):  .plinth/protected-paths"
  else
    printf '# One grep -E pattern per line; the driver must not edit matching paths.\n# Under a Claude driver the guard blocks such edits at the tool level. (Version-pinned Plinth\n# tooling here is also checked by the review as tampering; project-owned entries like config\n# are reviewed as normal project code.) Use (^|/)name anchoring, not ^name: agent file paths\n# are often absolute. Version-pinned tooling updates come via plinth update.\n(^|/)\\.plinth/session/\n(^|/)\\.plinth/config$\n(^|/)\\.claude/hooks/\n(^|/)\\.claude/agents/grok-implementer\\.md$\n(^|/)\\.claude/agents/codex-implementer\\.md$\n(^|/)\\.claude/settings\\.json$\n(^|/)\\.plinth/review\\.sh$\n(^|/)\\.plinth/risk-classify\\.sh$\n(^|/)\\.plinth/lane-guard\\.sh$\n(^|/)\\.plinth/review-schema\\.json$\n(^|/)\\.plinth/plinth-rules\\.md$\n(^|/)\\.plinth/MODELS\\.md$\n(^|/)\\.plinth/reviewer\\.md$\n(^|/)\\.plinth/protected-paths$\n(^|/)CLAUDE\\.md$\n(^|/)AGENTS\\.md$\n' > "$target/.plinth/protected-paths"
    echo "  created:       .plinth/protected-paths"
  fi
  if [ -f "$target/.plinth/config" ]; then
    echo "  kept (yours):  .plinth/config"
  else
    printf '# Plinth per-project config. Never overwritten by plinth update.\n# The driver must not edit this (it is in protected-paths): under a Claude driver the guard\n# blocks edits at the tool level; a change is otherwise reviewed as normal project code.\n# Knobs (all optional, set-once):\n# spec_path: canonical spec — file (SPEC.md) or directory tree (spec/).\n# exec_gated: space-separated grep -E patterns for execution-gated paths;\n#   RUNTIME: review findings there route to the run gate instead of blocking.\n# smoke_cmd: the real-run command the Smoke workflow executes on the\n#   self-hosted runner (empty = smoke job no-ops green).\n# tier2_extra: grep -E pattern for project paths that must always get the\n#   full (Tier 2) adversarial review (risk-classify.sh floors the tier here).\n# reviewer_vendor: PRIMARY reviewer CLI — codex (OpenAI), claude (Anthropic), or\n#   grok (xAI). Default codex. Who runs the primary adversarial review (distinct\n#   from audit_vendor, the cross-vendor SECOND opinion). Must be installed + signed\n#   in. codex/claude resume warm threads across fix rounds; grok runs fresh.\n# reviewer_model_tier1 / reviewer_model_tier2: optional per-tier reviewer model\n#   (passed to the reviewer as its model flag). Unset = the vendor default model.\n#   Set a cheaper model for tier1 to cut cost; the frontier model for tier2.\n# audit_vendor: subscription CLI for the cross-vendor Tier-2 second opinion —\n#   codex (OpenAI), claude (Anthropic), grok (xAI), or agy (Google Antigravity).\n#   The audit runs only\n#   when audit_vendor differs from reviewer_vendor (the primary). The scaffold sets\n#   audit_vendor = claude (below) with the default reviewer_vendor = codex, so in a fresh\n#   project the cross-vendor audit IS ON (every Tier 2 approval, every 5th else) and the\n#   auditor is a different family than BOTH the grok WORKER (the usual diff producer)\n#   and the codex reviewer — true in both the architect-resident default and the\n#   grok-resident alternative. An unset\n#   audit_vendor DEFAULTS to codex, so it runs unless reviewer_vendor is also codex; to turn\n#   it off, set audit_vendor equal to reviewer_vendor. Use a DIFFERENT vendor to keep it on.\n#   All are subscription-authenticated (no per-use cost).\n# audit_model: optional model override for audit_vendor (NOT a trigger — the\n#   cross-vendor audit runs only when audit_vendor is a DIFFERENT vendor than\n#   reviewer_vendor, the primary). When it runs: every Tier 2 approval, every 5th else.\n# advisor_vendor: CLI for `plinth advise` — claude|codex|grok|agy. Default claude.\n#   The advisor is a COLLABORATIVE, non-blocking, driver-initiated consult of a model\n#   as good or BETTER than the driver (distinct from the adversarial reviewer and the\n#   auditor). Cross-family is fine: a grok driver can set advisor_vendor = claude to\n#   consult Fable.\n# advisor_model / advisor_model_max: peer-tier and escalated-tier advisor model.\n#   `plinth advise` uses advisor_model; `plinth advise --impactful` (architectural /\n#   high-consequence decisions) uses advisor_model_max. Both should be >= the driver\n#   model. Unset = the vendor default model (no escalation).\n# round_budget: advisory per-round input-token budget (default 4000000). Over it the\n#   review WARNS and continues (never blocks); spend is visible in plinth watch.\n# Recommended reviewer assignment (see .plinth/MODELS.md): primary reviewer\n#   codex/GPT (deepest); audit_vendor = claude (a different family than both the grok\n#   worker and the codex reviewer, in either topology) for the cross-vendor Tier-2 second opinion.\n#   Needs claude signed in; fails non-fatal if not.\n# Everything else has working defaults.\nspec_path = SPEC.md\naudit_vendor = claude\n# v4 audit seat model: Opus 4.8 (the seat is Claude OPUS, not the CLI default —\n# an operator whose claude CLI defaults to Sonnet/Fable would otherwise audit\n# with a different model than the assignment promises):\naudit_model = opus\n# v4 advisor seat (plinth advise): peer = Opus 4.8, --impactful = Fable 5 (credits).\n# advise is NON-BLOCKING, so a missing model/CLI just reports unavailable. Model\n# names are per-vendor — change them if you change advisor_vendor.\nadvisor_model = opus\nadvisor_model_max = fable\n# v4 reviewer seat: GPT-5.6 GA landed July 9 2026, but access is PER-ACCOUNT and\n# needs Codex CLI >= 0.144.0 — uncomment once codex -m gpt-5.6 works for you.\n# An ACTIVE line on an ineligible account makes the reviewer FAIL LOUD, not\n# fall back — that is why these ship commented.\n# reviewer_model_tier1 = gpt-5.6\n# reviewer_model_tier2 = gpt-5.6\n' > "$target/.plinth/config"
    echo "  created:       .plinth/config"
  fi
  place .github/workflows/smoke.yml .github/workflows/smoke.yml
  if [ -f "$target/.github/workflows/ci.yml" ]; then
    echo "  kept (yours):  .github/workflows/ci.yml"
  else
    cp "$PLINTH_ROOT/templates/.github/workflows/ci.yml" "$target/.github/workflows/ci.yml"
    owner="$(detect_owner)"
    if [ -n "$owner" ]; then
      edit_file "$target/.github/workflows/ci.yml" -e "s|OWNER/plinth/|${owner}/plinth/|g"
      echo "  created:       .github/workflows/ci.yml (OWNER='$owner' auto-detected)"
    else
      echo "  created:       .github/workflows/ci.yml — WARNING: owner undetected, edit OWNER manually"
    fi
    # Pin the reusable-workflow refs to the SHA of the Plinth release being
    # installed (immutable — no mutable tag to trust or suppress). If HEAD can't be
    # resolved (non-git checkout), fail LOUD instead: the else branch rewrites the
    # refs to an unpinned sentinel so CI errors until the operator pins them — never
    # a silently-stale floor. BRE-portable sed (no alternation) for macOS BSD sed.
    psha="$(git -C "$PLINTH_ROOT" rev-parse HEAD 2>/dev/null || true)"
    if [ -n "$psha" ]; then
      edit_file "$target/.github/workflows/ci.yml" \
        -e "s|plinth-floor\.yml@[0-9a-f]*|plinth-floor.yml@${psha}|g" \
        -e "s|plinth-checks\.yml@[0-9a-f]*|plinth-checks.yml@${psha}|g" \
        -e "s|# v4\.1\.9 (plinth init repins)|# v${PLINTH_VERSION} (pinned by plinth init from this checkout)|g"
    else
      # Fail LOUD, never silently-stale: if we can't resolve the release commit,
      # replace the shipped fallback SHA with an UNPINNED sentinel so CI errors on
      # the unresolved ref until the operator pins it — rather than quietly running
      # a prior release's floor/checks. BRE-portable sed (backref, no alternation).
      edit_file "$target/.github/workflows/ci.yml" \
        -e "s|\(plinth-floor\.yml@\)[0-9a-f]*|\1PIN_TO_YOUR_PLINTH_RELEASE_COMMIT|g" \
        -e "s|\(plinth-checks\.yml@\)[0-9a-f]*|\1PIN_TO_YOUR_PLINTH_RELEASE_COMMIT|g" \
        -e "s|# v4\.1\.9 (plinth init repins)|# UNPINNED — set to your Plinth release commit SHA|g"
      echo "  ci.yml:        WARNING — could not resolve the Plinth commit SHA (PLINTH_ROOT is not a"
      echo "                 git checkout?). Left the reusable-workflow refs UNPINNED"
      echo "                 (PIN_TO_YOUR_PLINTH_RELEASE_COMMIT) so CI fails loudly until you set"
      echo "                 them to this Plinth version's commit SHA — no silently-stale floor."
    fi
  fi
}

# NEEDS-HUMAN items are often multi-line markdown: emit one LOGICAL item per
# line (continuations joined), open ("- [ ]") items only, falling back to any
# non-blank content. Shared by watch and `plinth queue`.
open_items() {  # open_items <needs-human-file>
  awk '
    /^- \[ \]/ { if (cur != "") print cur; cur = substr($0, 7); next }
    /^- \[/    { if (cur != "") print cur; cur = ""; next }
    /^#/       { if (cur != "") print cur; cur = ""; next }
    cur != ""  { line = $0; gsub(/^[[:space:]]+|[[:space:]]+$/, "", line);
                 if (line != "") cur = cur " " line; next }
    END        { if (cur != "") print cur }
  ' "$1" 2>/dev/null
}

# Blocking items first (order preserved within each group), so the human sees
# what's stalling work RIGHT NOW at the top. Reads logical items on stdin.
sort_blocking_first() {
  local all blk non
  all="$(cat)"
  blk="$(printf '%s\n' "$all" | grep '^\[BLOCKING\]' || true)"
  non="$(printf '%s\n' "$all" | grep -v '^\[BLOCKING\]' || true)"
  [ -n "$blk" ] && printf '%s\n' "$blk"
  [ -n "$non" ] && printf '%s\n' "$non"
  return 0   # never fail the caller's `x="$(... | sort_blocking_first)"` under set -e:
             # an all-BLOCKING (or all-non-blocking) queue leaves the final test false,
             # which would otherwise abort `plinth queue`/`watch` mid-render.
}

# Full queue, every item, folded to terminal width — the readable, scrollable
# home for long queues (the watch banner caps to what fits the screen).
run_queue() {
  local f; f="$(needs_human_file "$target")"
  [ -s "$f" ] || { echo "plinth queue: nothing pending in $f"; exit 0; }
  local cols wrapw items
  cols="${PLINTH_WATCH_COLS:-$(tput cols 2>/dev/null || echo 100)}"
  [ "$cols" -ge 40 ] 2>/dev/null || cols=100
  wrapw=$((cols - 4))
  items="$(open_items "$f")"
  [ -n "$items" ] || items="$(grep -v '^[[:space:]]*$' "$f")"
  local qb; qb="$(printf '%s\n' "$items" | grep -c '^\[BLOCKING\]' || true)"
  items="$(printf '%s\n' "$items" | sort_blocking_first)"
  echo "⏸ NEEDS-HUMAN — $target ($(printf '%s\n' "$items" | grep -c .) open, $qb blocking; blocking first)"
  local RD=$'\033[1;31m' Z=$'\033[0m'
  while IFS= read -r item; do
    [ -n "$item" ] || continue
    case "$item" in
      '[BLOCKING]'*) printf '%s· %s%s\n' "$RD" "$item" "$Z" | fold -s -w "$wrapw" | sed '2,$s/^/  /' ;;
      *)             printf '· %s\n' "$item" | fold -s -w "$wrapw" | sed '2,$s/^/  /' ;;
    esac
  done <<< "$items"
}

# ── plinth watch ──────────────────────────────────────────────────────────────
# Live session dashboard. Reads the raw event feed (.plinth/session/events.jsonl,
# written by pulse.sh) + the Claude Code transcript it points at + the review
# verdict, and renders task / stage pipeline / tokens / burn / gates every 2s.
# All interpretation lives here in one jq program — events stay raw facts.
render_frame() {
  local EV="$target/.plinth/session/events.jsonl" feedless=0
  if [ ! -f "$EV" ]; then
    # FEEDLESS mode — a codex/grok driver runs no .claude/ hooks, so pulse.sh never
    # creates the feed (same if the hooks are unwired). Do NOT bail: everything that
    # does not come from hooks still renders — review rounds + verdicts (review.sh
    # writes them for EVERY driver), the NEEDS-HUMAN queue, and branch state. The
    # hook-fed lines (task/stage/tokens/model/evidence) stay at their empty defaults.
    feedless=1; EV=/dev/null
    printf '\033[2m  no event feed (non-Claude driver, or pulse.sh unwired — CHANGELOG v3.8): hook-fed lines blank; review/queue/branch state live\033[0m\n'
  fi
  local transcript head branch slug
  transcript="$(jq -rs '[.[] | select(.transcript != null)] | last | .transcript // empty' "$EV" 2>/dev/null)"
  [ -f "$transcript" ] || transcript=/dev/null
  head="$(git -C "$target" rev-parse --short HEAD 2>/dev/null || echo '-')"
  branch="$(git -C "$target" symbolic-ref --short -q HEAD 2>/dev/null || echo '-')"
  slug="$(printf '%s' "$branch" | tr '/ ' '--')"
  local vfile="$target/.plinth/session/review/$slug/verdict.json"; [ -f "$vfile" ] || vfile=/dev/null
  local ufile="$target/.plinth/session/review/$slug/usage.jsonl"; [ -f "$ufile" ] || ufile=/dev/null
  # A round in flight: the newest request-N.json outruns verdict.json.
  local rqfile
  rqfile="$(ls "$target/.plinth/session/review/$slug"/request-*.json 2>/dev/null | sort -t- -k2 -n | tail -1 || true)"
  [ -n "$rqfile" ] && [ -f "$rqfile" ] || rqfile=/dev/null
  local rfile="$target/.plinth/session/run/$slug/receipt.json"; [ -f "$rfile" ] || rfile=/dev/null
  local nh="" nhn=0 nhb=0 nhf; nhf="$(needs_human_file "$target")"
  if [ -s "$nhf" ]; then
    # Open items = unchecked boxes; fall back to any non-blank line.
    # Full text, every item, SOFTWARE-WRAPPED to the terminal width with a
    # hanging indent: the in-place repaint assumes one logical line per
    # physical row, so we must never rely on the terminal to wrap.
    local raw cols wrapw item rows budget used=0 shown=0 folded flines
    raw="$(open_items "$nhf")"
    [ -n "$raw" ] || raw="$(grep -v '^[[:space:]]*$' "$nhf")"
    nhn="$(printf '%s\n' "$raw" | grep -c . || true)"
    nhb="$(printf '%s\n' "$raw" | grep -c '^\[BLOCKING\]' || true)"
    raw="$(printf '%s\n' "$raw" | sort_blocking_first)"   # blocking to the top
    cols="${PLINTH_WATCH_COLS:-$(tput cols 2>/dev/null || echo 100)}"
    [ "$cols" -ge 40 ] 2>/dev/null || cols=100
    wrapw=$((cols - 6))
    # The frame must fit the screen or the repaint loses its top: show as many
    # COMPLETE items as fit, then point at `plinth queue` for the rest.
    rows="${PLINTH_WATCH_ROWS:-$(tput lines 2>/dev/null || echo 40)}"
    [ "$rows" -ge 24 ] 2>/dev/null || rows=40
    # Reserve = fixed frame (~18 rows: banner, branch, models, pipeline+Σ, CI,
    # tokens/burn/review/run/evidence/signals/now) + queue sep/header + footer.
    budget=$((rows - 23)); [ "$budget" -ge 2 ] || budget=2
    # Each physical line carries a 1-char tag jq reads for color: "!" blocking,
    # " " normal. Blocking items are already partitioned to the top.
    local tag
    while IFS= read -r item; do
      [ -n "$item" ] || continue
      case "$item" in '[BLOCKING]'*) tag='!' ;; *) tag=' ' ;; esac
      folded="$(printf '%s\n' "· $item" | fold -s -w "$wrapw" | sed '2,$s/^/  /')"
      flines="$(printf '%s\n' "$folded" | wc -l | tr -d ' ')"
      if [ $((used + flines)) -gt "$budget" ] && [ "$shown" -gt 0 ]; then break; fi
      while IFS= read -r pl; do nh+="${tag}${pl}"$'\n'; done <<< "$folded"
      used=$((used + flines)); shown=$((shown + 1))
      [ "$used" -ge "$budget" ] && break
    done <<< "$raw"
    if [ "$shown" -lt "$nhn" ]; then
      nh+=" … +$((nhn - shown)) more — full queue: plinth queue $target"$'\n'
    fi
    nh="${nh%$'\n'}"
  fi

  # Live CI row once the feed shows a PR: pull the check rollup from GitHub.
  # PLINTH_CI_STATUS ('{"pass":N,"fail":N,"pending":N}') overrides for non-gh CIs.
  local ci="null"
  if [ -n "${PLINTH_CI_STATUS:-}" ]; then
    ci="$PLINTH_CI_STATUS"
  elif grep -qE 'gh pr (create|merge)' "$EV" 2>/dev/null && command -v gh >/dev/null 2>&1; then
    ci="$( (cd "$target" && gh pr view --json statusCheckRollup 2>/dev/null) | jq -c '
      {pass:    ([.statusCheckRollup[]? | select(.conclusion=="SUCCESS" or .state=="SUCCESS")] | length),
       fail:    ([.statusCheckRollup[]? | select(.conclusion=="FAILURE" or .conclusion=="ERROR" or .conclusion=="CANCELLED" or .state=="FAILURE" or .state=="ERROR")] | length),
       pending: ([.statusCheckRollup[]? | select(.status=="IN_PROGRESS" or .status=="QUEUED" or .status=="PENDING" or .state=="PENDING")] | length)}' 2>/dev/null)"
    [ -n "$ci" ] || ci="null"
  fi

  jq -rn --slurpfile ev "$EV" --slurpfile tr "$transcript" --slurpfile vd "$vfile" \
        --slurpfile us "$ufile" --slurpfile rc "$rfile" --slurpfile rq "$rqfile" \
        --arg nh "$nh" --argjson nhn "${nhn:-0}" --argjson nhb "${nhb:-0}" \
        --arg head "$head" --arg branch "$branch" --argjson ci "$ci" '
    # ---------- helpers ----------
    def B: "[1m";  def D: "[2m";  def R: "[0m";
    def CY: "[36m"; def GR: "[32m"; def YE: "[33m";
    def RD: "[31m"; def MG: "[35m"; def RV: "[7m";
    def rpad(n): (. + (" " * n))[0:n];
    def hum_t: if . == null or . < 0 then "—"
      elif . < 60 then "\(. | floor)s"
      elif . < 3600 then "\((. / 60) | floor)m \((. % 60) | floor)s"
      else "\((. / 3600) | floor)h \(((. % 3600) / 60) | floor)m" end;
    def hum_k: if . == null then "—"
      elif . >= 1000000 then "\(. / 1000000 * 10 | floor / 10)M"
      elif . >= 1000 then "\(. / 1000 * 10 | floor / 10)k"
      else "\(.)" end;
    def ago($now): ($now - .) | hum_t + " ago";

    ($ev | map(select(type == "object"))) as $all
    | (now | floor) as $NOW
    # focus: the most recently ACTIVE session — not the last SessionStart;
    # sessions that predate their own wiring have no start event (certeus bug)
    | (([$all[] | select(.sid != null)] | .[-1].sid)) as $sid
    | ($all | map(select(.sid == $sid))) as $sev
    | if ($sev | length) == 0 then
        # REDUCED frame — no session events (feedless: a codex/grok driver runs no
        # .claude/ hooks; or a wired session that has not pulsed yet). Render what
        # does NOT come from hooks: identity, review state (review.sh writes it for
        # every driver), and the NEEDS-HUMAN queue.
        ([ (B + "  " + $branch + " @ " + $head + R + "  " + D + "(no session events)" + R),
           (($vd[0] // null) as $v |
             if $v == null then (D + "  review: none yet on this branch" + R)
             else ("  review: " +
               (if ($v.verdict // "") == "APPROVED" then GR else RD end) + ($v.verdict // "?") + R +
               D + " @ " + (($v.sha // "")[0:7]) + " round " + (($v.round // "?") | tostring) +
               " tier " + (($v.risk.tier // "?") | tostring) + R)
             end),
           (if $nhn > 0
            then (RD + "  NEEDS-HUMAN: " + ($nhn | tostring) + " open (" + ($nhb | tostring) + " blocking)" + R + "\n" + $nh)
            else empty end)
         ] | join("\n"))
      else

    ($sev[0].epoch) as $t0
    # ---------- stage classification (facts -> stages, renderer-side only) ----------
    | def stage_of:
        if .event == "PostToolUse" and (.tool == "Edit" or .tool == "Write" or .tool == "MultiEdit" or .tool == "NotebookEdit")
        then "IMPLEMENT"
        elif .event == "PostToolUse" and .tool == "Bash" then
          ((.detail // "") |
            if test("review\\.sh") then "REVIEW"
            elif test("gh pr (create|merge)") then "PR"
            elif test("(^|[;&|(\\s])(pytest|go test|cargo (test|nextest|check)|npm (test|run test)|yarn test|pnpm test|python3? -m (pytest|unittest)|make (test|check)|mix test|rspec|jest|vitest|tox|swift test)")
            then "VERIFY" else null end)
        else null end;
    ([{e: $t0, s: "PLAN"}] + [$sev[] | (stage_of) as $s | select($s != null) | {e: .epoch, s: $s}]) as $marks
    # collapse consecutive same-stage marks, then close segments
    | ($marks | reduce .[] as $m ([]; if ((.[-1].s) // "") == $m.s then . else . + [$m] end)) as $tx
    | [range(0; $tx | length) | {s: $tx[.].s, a: $tx[.].e, b: (if . + 1 < ($tx | length) then $tx[. + 1].e else $NOW end)}] as $segs
    | ($segs[-1].s) as $cur
    # ---------- tokens from the transcript ----------
    | ($tr | map(select(type == "object" and .type == "assistant" and (.message.usage? != null))
        | {e: ((.timestamp // "") | sub("\\.[0-9]+Z$"; "Z") | try fromdate catch null),
           i: (.message.usage.input_tokens // 0), cc: (.message.usage.cache_creation_input_tokens // 0),
           cr: (.message.usage.cache_read_input_tokens // 0), o: (.message.usage.output_tokens // 0),
           m: (.message.model // null)}
        | select(.e != null))) as $use
    | {i: ($use | map(.i) | add // 0), cc: ($use | map(.cc) | add // 0),
       cr: ($use | map(.cr) | add // 0), o: ($use | map(.o) | add // 0)} as $tot
    | ([$segs | group_by(.s)[] | {s: .[0].s,
         t: (map(.b - .a) | add),
         k: (map(. as $g | [$use[] | select(.e >= $g.a and .e < $g.b) | .i + .cc + .o] | add // 0) | add)}]) as $per
    | ([$use[] | select(.e > $NOW - 300) | .i + .cc + .o] | add // 0) as $last5
    # sparkline: 12 one-minute buckets
    | (["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]) as $bars
    | ([range(0; 12) | . as $b | [$use[] | select(.e > $NOW - (12 - $b) * 60 and .e <= $NOW - (11 - $b) * 60) | .i + .cc + .o] | add // 0]) as $bkt
    | (($bkt | max) // 0) as $bmax
    | ($bkt | map(if $bmax == 0 then "▁" else $bars[(. / $bmax * 7) | floor] end) | join("")) as $spark
    # ---------- signals ----------
    | ([$all[] | select(.event == "guard_block" and .epoch >= $t0)] | length) as $blocks
    | ([$all[] | select(.event == "gate_release" and .epoch >= $t0)] | length) as $releases
    | ([$sev[] | select(.event == "PreCompact")] | length) as $compacts
    | ([$sev[] | select(.event == "SubagentStop")] | length) as $subs
    | (([$sev[] | select(.event == "UserPromptSubmit") | .detail // ""
         | select((test("^\\s*<") | not) and length > 0)] | .[-1]) // "(no prompt recorded)") as $task
    | ([$sev[] | select((stage_of) == "VERIFY")] | .[-1]) as $evd
    | ([$sev[] | select(.event == "PostToolUse")] | .[-1]) as $lastact
    | (($use | map(.m) | map(select(. != null)) | .[-1]) // "—") as $model
    | ($vd[0] // null) as $V
    # ---------- frame ----------
    | (["PLAN", "IMPLEMENT", "VERIFY", "REVIEW", "PR"]) as $ORDER
    | ([ $ORDER[] | . as $s | ($per | map(select(.s == $s)) | .[0]) as $p
        | if $p == null then D + "   " + ($s | rpad(10)) + ("—" | rpad(10)) + "—" + R
          elif $s == $cur then RV + B + " ▶ " + ($s | rpad(10)) + (($p.t | hum_t) | rpad(10)) + (($p.k | hum_k) + " tok")
               + "  · now " + ((($NOW - $segs[-1].a) | hum_t)) + R
          else GR + " ✓ " + R + ($s | rpad(10)) + (($p.t | hum_t) | rpad(10)) + D + (($p.k | hum_k) + " tok") + R
          end ] | join("\n")) as $pipe0
    | ($pipe0 + "\n" + D + " Σ TOTAL    " + ((($per | map(.t) | add) // 0 | hum_t) | rpad(10))
        + ((($per | map(.k) | add) // 0 | hum_k) + " tok") + R) as $pipe0
    | ($pipe0 + (if $ci == null then "" else "\n"
        + (if ($ci.fail // 0) > 0 then RD elif ($ci.pending // 0) > 0 then YE else GR end)
        + "   CI        " + "✓\($ci.pass // 0)  ✗\($ci.fail // 0)  ◌\($ci.pending // 0)" + R end)) as $pipe
    | (($rq[0] // null) as $RQ
       | if $RQ != null and ($RQ.round // 0) > (($V.round // 0)) then
           YE + "round \($RQ.round) RUNNING (\($RQ.mode))" + R
           + (($RQ.ts // "" | sub("\\.[0-9]+Z$"; "Z") | try fromdate catch null) as $rs
              | if $rs != null then D + " · " + (($NOW - $rs) | hum_t) + " in" + R else "" end)
           + D + " · last verdict: " + ($V.verdict // "none") + " r\($V.round // 0)" + R
         else null end) as $running
    | (if $running != null then $running
       elif $V == null then D + "no review round yet — ./.plinth/review.sh" + R
       else ((if $V.verdict == "APPROVED" then GR else YE end) + $V.verdict + R
         + D + " · round " + ($V.round | tostring) + " @ " + ($V.sha[0:7]) + R
         + (if ($V.sha[0:7]) == $head then GR + " = HEAD ✓" + R else RD + " ≠ HEAD " + $head + " — stale, re-run review" + R end)
         + (if $V.usage then D + " · reviewer " + ($V.usage.input_tokens | hum_k) + " in / " + ($V.usage.output_tokens | hum_k) + " out" + R else "" end)
         + (($us | map(.usage.input_tokens // 0) | add // 0) as $rtot
            | if $rtot > 0 then D + " · Σ " + ($rtot | hum_k) + " in" + R else "" end)
         + (if $V.audit then (if ($V.audit.verdict // "") == "UNAVAILABLE" then YE + " · audit unavailable" + R elif ($V.audit.blocking // 0) > 0 then RD + " · AUDIT DISAGREES (\($V.audit.blocking))" + R else D + " · audit ✓" + R end) else "" end))
       end) as $review
    | (if ($rc | length) == 0 then D + "no run receipt — RUNTIME findings await plinth smoke" + R
       else ($rc[0]) as $R
         | (if ($R.exit // 1) == 0 then GR + "exit 0" + R else RD + "exit \($R.exit)" + R end)
           + D + " · " + (($R.cmd // "?")[0:44]) + " · " + (($R.ended // $NOW) | ago($NOW)) + " @ " + (($R.sha // "")[0:7]) + R
       end) as $runline
    | (if $evd == null then D + "no test runner seen this session" + R
       else ($evd.detail[0:56])
         + (if $evd.rc == 0 then GR + " → exit 0" + R
            elif $evd.rc != null then RD + " → exit \($evd.rc)" + R
            else D + " → ran" + R end)
         + D + " · " + ($evd.epoch | ago($NOW)) + R
       end) as $evidence
    | (if $lastact == null then D + "—" + R
       else ($lastact.tool // "?") + D + " " + (($lastact.detail // "")[0:56]) + " · " + ($lastact.epoch | ago($NOW)) + R end) as $nowline

    | ($V.model // null) as $rmodel
    | B + CY + " ◤ PLINTH WATCH " + R + B + ($task[0:58]) + R + "\n"
    + D + "   " + $branch + " @ " + $head + " · session " + (($NOW - $t0) | hum_t) + R + "\n"
    + B + " models   " + R + "driver " + CY + $model + R
      + "  ·  reviewer " + CY + ($rmodel // "—") + R
      + (if $rmodel == null then D + " (no review yet)" + R else "" end) + "\n"
    + D + " ─────────────────────────────────────────────────────────────────" + R + "\n"
    + $pipe + "\n"
    + D + " ─────────────────────────────────────────────────────────────────" + R + "\n"
    + B + " tokens   " + R + (($tot.i + $tot.cc + $tot.cr + $tot.o) | hum_k)
      + D + "  (in " + ($tot.i | hum_k) + " · cache-write " + ($tot.cc | hum_k) + " · cache-read " + ($tot.cr | hum_k) + " · out " + ($tot.o | hum_k) + ")" + R + "\n"
    + B + " burn     " + R + (($last5 / 5 | floor) | hum_k) + "/min  " + MG + $spark + R + D + "  (last 12 min, fresh+out)" + R + "\n"
    + B + " review   " + R + $review + "\n"
    + B + " run      " + R + $runline + "\n"
    + B + " evidence " + R + $evidence + "\n"
    + B + " signals  " + R
      + (if $blocks > 0 then RD + "guard blocks \($blocks)" + R else D + "guard blocks 0" + R end)
      + (if $releases > 0 then RD + " · GATE RELEASES \($releases) — unreviewed work escaped the session gate" + R
         else D + " · gate releases 0" + R end)
      + D + " · compactions \($compacts) · subagent runs \($subs)" + R + "\n"
    + B + " now      " + R + $nowline
    # Variable-height content lives at the BOTTOM: the fixed dashboard keeps a
    # stable screen position; the queue grows downward where it displaces nothing.
    + (if $nh != "" then
         "\n" + D + " ─────────────────────────────────────────────────────────────────" + R + "\n"
         + (if $nhb > 0 then B + RD + RV else RD + RV end)
           + " ⏸ NEEDS HUMAN (\($nhn) open\(if $nhb > 0 then " · \($nhb) BLOCKING" else "" end)) " + R + "\n"
         # Per-line tag: "!" blocking -> bold bright red; " " normal -> dim.
         + ([$nh | split("\n")[] | select(length > 0)
             | if (.[0:1]) == "!" then B + RD + "   " + (.[1:]) + R
               else D + "   " + (.[1:]) + R end] | join("\n"))
       else "" end)
    end
  ' 2>/dev/null || echo "plinth watch: render error (malformed event or transcript line?)"
}

# Execution evidence: run a real command and write a SHA-bound receipt the
# review loop consumes (RUNTIME findings get verified against observation,
# not guesses). Failures are data — the receipt records them the same way.
run_smoke() {
  shift 2   # drop 'smoke' <path>
  [ "${1:-}" = "--" ] && shift
  [ $# -ge 1 ] || usage
  local br rslug rdir ts log start end rc=0
  br="$(git -C "$target" symbolic-ref --short -q HEAD 2>/dev/null || echo detached)"
  rslug="$(printf '%s' "$br" | tr '/ ' '--')"
  rdir="$target/.plinth/session/run/$rslug"
  mkdir -p "$rdir"
  [ -f "$target/.plinth/session/.gitignore" ] || printf '*\n' > "$target/.plinth/session/.gitignore"
  ts="$(date -u +%Y%m%dT%H%M%SZ)"; log="$rdir/smoke-$ts.log"
  echo "plinth smoke [$br]: $*"
  start="$(date +%s)"
  ( cd "$target" && "$@" ) 2>&1 | tee "$log" || rc=$?
  end="$(date +%s)"
  jq -n --arg sha "$(git -C "$target" rev-parse HEAD 2>/dev/null || echo none)" \
        --arg branch "$br" --arg cmd "$*" --argjson exit "${rc:-0}" \
        --argjson started "$start" --argjson ended "$end" \
        --arg hw "$(uname -m) · $(sysctl -n machdep.cpu.brand_string 2>/dev/null || uname -s)" \
        --arg log "$log" --arg tail "$(tail -n 40 "$log" 2>/dev/null)" \
        '{sha: $sha, branch: $branch, cmd: $cmd, exit: $exit, started: $started, ended: $ended,
          secs: ($ended - $started), hw: $hw, log: $log, log_tail: $tail}' \
        > "$rdir/receipt.json"
  echo "plinth smoke: exit ${rc:-0} in $((end - start))s · receipt: $rdir/receipt.json"
  exit "${rc:-0}"
}

# One-line renderer for Claude Code's statusLine setting. Reads the statusLine
# JSON on stdin (workspace dir), or takes an explicit project path. Consults
# only the event feed + verdict — no transcript parse, cheap at statusline
# cadence. Token economics stay on `plinth watch`.
statusline_render() {
  local in dir
  in="$(cat 2>/dev/null || true)"
  dir="$target"
  [ -n "$dir" ] || dir="$(printf '%s' "$in" | jq -r '.workspace.current_dir // .cwd // empty' 2>/dev/null)"
  { [ -n "$dir" ] && [ -d "$dir" ]; } || exit 0
  local EV="$dir/.plinth/session/events.jsonl"
  [ -f "$EV" ] || { printf 'plinth: no session feed'; exit 0; }
  local head vfile
  head="$(git -C "$dir" rev-parse --short HEAD 2>/dev/null || echo '-')"
  local sslug nh=""
  sslug="$(git -C "$dir" symbolic-ref --short -q HEAD 2>/dev/null | tr '/ ' '--')"
  vfile="$dir/.plinth/session/review/${sslug:-detached}/verdict.json"; [ -f "$vfile" ] || vfile=/dev/null
  local nhblk="" nhf; nhf="$(needs_human_file "$dir")"
  if [ -s "$nhf" ]; then
    nh="$(grep -cE '^- \[ \]' "$nhf" 2>/dev/null || echo 1)"
    nhblk="$(grep -cE '^- \[ \] \[BLOCKING\]' "$nhf" 2>/dev/null || true)"
    [ "$nhblk" != "0" ] && [ -n "$nhblk" ] && nh="${nh}⛔${nhblk}"
  fi
  jq -rn --slurpfile ev "$EV" --slurpfile vd "$vfile" --arg head "$head" --arg nh "$nh" '
    def hum_t: if . < 60 then "\(. | floor)s" elif . < 3600 then "\((. / 60) | floor)m"
      else "\((. / 3600) | floor)h\(((. % 3600) / 60) | floor)m" end;
    ($ev | map(select(type == "object"))) as $all
    | (now | floor) as $NOW
    | (([$all[] | select(.sid != null)] | .[-1].sid)) as $sid
    | ($all | map(select(.sid == $sid))) as $sev
    | if ($sev | length) == 0 then "plinth: no session" else
      ($sev[0].epoch) as $t0
      | def stage_of:
          if .event == "PostToolUse" and (.tool == "Edit" or .tool == "Write" or .tool == "MultiEdit" or .tool == "NotebookEdit")
          then "IMPLEMENT"
          elif .event == "PostToolUse" and .tool == "Bash" then
            ((.detail // "") |
              if test("review\\.sh") then "REVIEW"
              elif test("gh pr (create|merge)") then "PR"
              elif test("(^|[;&|(\\s])(pytest|go test|cargo (test|nextest|check)|npm (test|run test)|yarn test|pnpm test|python3? -m (pytest|unittest)|make (test|check)|mix test|rspec|jest|vitest|tox|swift test)")
              then "VERIFY" else null end)
          else null end;
      (([{e: $t0, s: "PLAN"}] + [$sev[] | (stage_of) as $s | select($s != null) | {e: .epoch, s: $s}])
        | reduce .[] as $m ([]; if ((.[-1].s) // "") == $m.s then . else . + [$m] end) | .[-1]) as $cur
      | ($vd[0] // null) as $V
      | (if $V == null then "no review"
         elif $V.verdict == "APPROVED" and ($V.sha[0:7]) == $head then "APPROVED ✓"
         elif $V.verdict == "APPROVED" then "APPROVED (stale)"
         else "CHANGES r\($V.round)" end) as $rv
      | ([$all[] | select(.event == "guard_block" and .epoch >= $t0)] | length) as $b
      | ([$all[] | select(.event == "gate_release" and .epoch >= $t0)] | length) as $r
      | "◆ " + $cur.s + " " + (($NOW - $cur.e) | hum_t) + " · " + $rv
        + (if $nh != "" and $nh != "0" then " · ⏸ HUMAN×" + $nh else "" end)
        + (if $b > 0 then " · guard⛔\($b)" else "" end)
        + (if $r > 0 then " · RELEASED \($r)" else "" end)
      end'
}

# Inside $(render_frame) tput talks to a pipe and reports 24×80 regardless of
# the real window, starving the queue budget. Read the size from the TTY and
# hand it down via the PLINTH_WATCH_* overrides (honoring any the user set).
capture_tty_size() {
  local _sz
  # Test that the controlling tty can actually be OPENED (a device node may
  # exist but be unconfigured, e.g. a headless/background context) — the
  # subshell swallows the open error instead of leaking it to stderr.
  ( : </dev/tty ) 2>/dev/null || return 0   # no controlling tty: keep default sizing
  if _sz="$(stty size </dev/tty 2>/dev/null)"; then
    [ -n "${PLINTH_WATCH_ROWS_USER:-}" ] || export PLINTH_WATCH_ROWS="${_sz% *}"
    [ -n "${PLINTH_WATCH_COLS_USER:-}" ] || export PLINTH_WATCH_COLS="${_sz#* }"
  fi
}

watch_project() {
  # User-provided sizes win permanently; otherwise track the TTY per repaint.
  [ -n "${PLINTH_WATCH_ROWS:-}" ] && export PLINTH_WATCH_ROWS_USER=1
  [ -n "${PLINTH_WATCH_COLS:-}" ] && export PLINTH_WATCH_COLS_USER=1
  if [ "$opt" = "--once" ]; then capture_tty_size; render_frame; exit 0; fi
  local EV="$target/.plinth/session/events.jsonl"
  local wslug VD
  wslug="$(git -C "$target" symbolic-ref --short -q HEAD 2>/dev/null | tr '/ ' '--')"
  VD="$target/.plinth/session/review/${wslug:-detached}/verdict.json"
  # mtime+size stamp, BSD then GNU stat.
  fstamp() { stat -f '%m %z' "$1" 2>/dev/null || stat -c '%Y %s' "$1" 2>/dev/null || echo 0; }
  # Alt screen + hidden cursor; restore on exit. Clear once at startup only.
  printf '\033[?1049h\033[?25l\033[2J'
  trap 'printf "\033[?25h\033[?1049l"; exit 0' INT TERM
  local last="" beat=10 stamp frame
  while :; do
    # Cheap 1s poll on file stamps; re-render (jq over feed + transcript) only
    # on change, plus a 10s heartbeat so elapsed/ago clocks stay live.
    stamp="$(fstamp "$EV") $(fstamp "$VD")"
    if [ "$stamp" != "$last" ] || [ "$beat" -ge 10 ]; then
      last="$stamp"; beat=0
      capture_tty_size   # per repaint: window resizes tracked
      # Repaint in place: home cursor, overwrite each line erasing its tail
      # (ESC[K), then erase below the frame (ESC[J). No full clear, no blink.
      frame="$(render_frame; printf '\n\033[2m  live — repaints on activity · plinth queue for the full list · ctrl-c to quit\033[0m')"
      # HARD CAP: never emit more lines than the viewport. One extra line
      # scrolls the terminal, and the next cursor-home lands mid-frame — the
      # top (identity, models) rolls off. Capping preserves the top always;
      # the queue budget already keeps the important rows above the cut.
      local trows="${PLINTH_WATCH_ROWS:-$(tput lines 2>/dev/null || echo 40)}"
      [ "$trows" -ge 10 ] 2>/dev/null || trows=40
      printf '\033[H'
      printf '%s\n' "$frame" | head -n $((trows - 1)) | sed $'s/$/\033[K/'
      printf '\033[J'
    fi
    beat=$((beat + 1))
    sleep 1
  done
}

# plinth advise [--impactful] "<question>" — consult a model as good or BETTER than
# the driver, READ-ONLY, and print its guidance. COLLABORATIVE + non-blocking +
# driver-initiated (distinct from the adversarial reviewer and the auditor). Works
# for ANY driver and cross-family: a grok driver with advisor_vendor=claude consults
# Fable. --impactful (architectural / high-consequence / irreversible-shape decisions,
# NOT merely "hard") escalates to advisor_model_max. A router could later replace this
# dispatch without changing the surface (advisor_vendor/advisor_model/_max). If the
# advisor CLI is missing or unauthed, say so and let the driver proceed — never a hard
# dependency.
run_advise() {
  shift  # drop 'advise'
  local impactful=0
  if [ "${1:-}" = "--impactful" ]; then impactful=1; shift; fi
  local question="${1:-}"
  [ -n "$question" ] || { echo "usage: plinth advise [--impactful] \"<question>\"" >&2; exit 1; }
  aval() { sed -n "s/^$1[[:space:]]*=[[:space:]]*//p" ".plinth/config" 2>/dev/null | head -1; }
  local vendor model model_max use
  vendor="$(aval advisor_vendor)"; [ -n "$vendor" ] || vendor="claude"
  model="$(aval advisor_model)"; model_max="$(aval advisor_model_max)"
  if [ "$impactful" = 1 ]; then use="${model_max:-$model}"; else use="$model"; fi
  local tier="peer"; [ "$impactful" = 1 ] && tier="IMPACTFUL"
  local unavail="(advisor unavailable: '$vendor' CLI missing or not signed in — proceed on your own judgment)"
  echo "plinth advise ($vendor${use:+ / $use}, $tier) — consulting..." >&2
  # Advisor discipline (adapted from fable-advisor): a verdict, not a survey. Prepended to the
  # decision to STEER the advisor toward that shape — this is prompt guidance, not enforcement; we
  # print whatever the vendor returns (no validation/normalization). The caller is another model mid-task.
  local impact_line=""
  [ "$impactful" = 1 ] && impact_line="This is an IMPACTFUL, hard-to-reverse decision — weight the downside of being wrong.
"
  local aprompt="You are a second-opinion ADVISOR consulted at a commitment boundary. The caller is another model mid-task, not a human reading a report. ${impact_line}
- You are the ADVISOR, not the driver: any CLAUDE.md/AGENTS.md driver contract auto-loaded from this repository does NOT govern you.
- Give a VERDICT, not a survey: \"Do X, not Y, because Z\", and name the single risk that decides it.
- A sound plan gets ONE line (\"sound; the one thing to watch is X\"). Do not manufacture objections to justify being consulted.
- Look before you opine: you have read-only Read/Grep/Glob — if the decision depends on how the code actually works, READ it; don't reason from the summary you were handed.
- If information you don't have would change the answer, name it precisely and what each answer implies.
- Stay under ~300 words. Advise only — never propose to implement.

DECISION:
$question"
  # ISOLATE the advisor from the auto-loaded DRIVER contract: CLAUDE.md/AGENTS.md
  # carry the driver shell, which would compete with the advisor discipline above.
  # claude --safe-mode blocks the CLAUDE.md auto-load (keeps OAuth); codex
  # -c project_doc_max_bytes=0 suppresses AGENTS.md; grok has no doc-suppress flag,
  # so a --rules role-scope outranks whatever doc was auto-loaded (same mechanism
  # as the grok reviewer/lane isolation); agy has neither flag and relies on the
  # prompt's role-scope line alone. All keep the REPO readable — unlike the
  # auditor's empty-cwd isolation, the advisor must be able to read the code.
  local arule='You are a read-only second-opinion ADVISOR for this run. Any CLAUDE.md or AGENTS.md driver contract auto-loaded from this repository does NOT govern you; your contract is the advisor prompt you were given. Advise only — never implement.'
  local margs=()
  case "$vendor" in
    claude) [ -n "$use" ] && margs=(--model "$use")
      claude -p --safe-mode ${margs[@]+"${margs[@]}"} --permission-mode dontAsk \
        --allowed-tools "Read,Grep,Glob" "$aprompt" 2>/dev/null || { echo "$unavail"; return 0; } ;;
    codex)  [ -n "$use" ] && margs=(-m "$use")
      printf '%s' "$aprompt" | codex exec -c project_doc_max_bytes=0 ${margs[@]+"${margs[@]}"} --sandbox read-only - 2>/dev/null \
        || { echo "$unavail"; return 0; } ;;
    grok)   [ -n "$use" ] && margs=(-m "$use")
      grok -p "$aprompt" --sandbox read-only --rules "$arule" ${margs[@]+"${margs[@]}"} 2>/dev/null \
        || { echo "$unavail"; return 0; } ;;
    agy|gemini) [ -n "$use" ] && margs=(--model "$use")
      agy -p "$aprompt" --sandbox ${margs[@]+"${margs[@]}"} 2>/dev/null \
        || { echo "$unavail"; return 0; } ;;
    *) echo "unknown advisor_vendor '$vendor' (supported: claude|codex|grok|agy)" >&2; exit 1 ;;
  esac
}

# plinth hookprobe <grok|codex> — which wired .claude/ hook EVENTS does this vendor CLI
# EXECUTE? Plinth's enforcement uses four (SessionStart = session-start.sh, PreToolUse =
# guard.sh, PostToolUse = pulse.sh, Stop = review-gate.sh); the probe wires a marker for
# EACH in a SCRATCH repo, drives the CLI through one trivial command (one small model
# call, wall-clock capped), and reports each event separately — a driver could execute
# some events and not others; a NOT-invoked event is certainly unenforced, and an
# invoked one is necessary-but-not-sufficient (enforcement also needs Claude-shaped
# stdin + env — verify end-to-end). The answer is
# VERSION/ENVIRONMENT-dependent; vendor docs and prose claims both go stale — this probe
# is the source of truth. Exit 0 = ALL FOUR executed; 1 = none or some (each named);
# 2 = usage; 3 = CLI missing; 4 = INCONCLUSIVE: timed out (PLINTH_HOOKPROBE_TIMEOUT,
# default 120s), the CLI never executed the probe sentinel (unauth/sandbox/model
# failure), or it exited nonzero AFTER the sentinel (a late failure could swallow
# late hook events such as Stop) — an inconclusive run is never hook evidence.
run_hookprobe() {
  shift  # drop 'hookprobe'
  # EXACTLY one vendor argument — no silent default (a bare `plinth hookprobe` must not
  # start a real model call), no ignored surplus args.
  [ "$#" = 1 ] || { echo "usage: plinth hookprobe <grok|codex>" >&2; exit 2; }
  local vendor="$1" d marker ver p ev report="" allfired=1 fired vrc=0
  local evs="SessionStart PreToolUse PostToolUse Stop"
  case "$vendor" in grok|codex) : ;; *) echo "usage: plinth hookprobe <grok|codex>" >&2; exit 2 ;; esac
  command -v "$vendor" >/dev/null 2>&1 || { echo "hookprobe: '$vendor' CLI not installed"; exit 3; }
  local d marker
  d="$(mktemp -d)" || { echo "hookprobe: could not create a scratch dir — INCONCLUSIVE (setup failed)"; exit 4; }
  marker="$d/hookmark"
  # The marker also CAPTURES stdin per event: Plinth's real hooks need Claude-shaped
  # JSON on stdin (and CLAUDE_PROJECT_DIR) to enforce anything, so invocation alone is
  # necessary but NOT sufficient — the report distinguishes the two.
  # Guard the whole setup subshell: under set -e a failed git-init/mkdir/probe-write/chmod would
  # exit 1 and COLLIDE with the NONE/SOME result code. A setup failure is not evidence about which
  # events fired — it must surface as INCONCLUSIVE (exit 4), never as "executed NONE".
  ( cd "$d" && git init -qb main . >/dev/null 2>&1 \
    && mkdir -p .claude/hooks \
    && printf '#!/usr/bin/env bash\necho "$1" >> "%s"\n[ -t 0 ] || head -c 4096 > "%s/payload-$1" 2>/dev/null\nexit 0\n' "$marker" "$d" > .claude/hooks/probe.sh \
    && chmod +x .claude/hooks/probe.sh ) \
    || { echo "hookprobe: could not build the scratch .claude probe harness — INCONCLUSIVE (setup failed)"; exit 4; }
  p="$d/.claude/hooks/probe.sh"
  # Build settings.json with a JSON ENCODER and SHELL-QUOTE the probe path. The scratch dir lives
  # under $TMPDIR; if that contains a space (or a quote/backslash), a hand-rolled JSON string would
  # (a) break the JSON, or (b) make the hook COMMAND split on the space so the vendor executes only
  # the prefix — the hook never fires, the marker stays empty, and hookprobe would FALSELY report
  # NONE. That directly contradicts the safety-critical claim that "NONE proves the events are
  # unenforced." json.dumps escapes the path for JSON; shlex.quote makes the command robust to a
  # metacharacter-bearing path. python3 is a declared dependency (see SETUP.md).
  python3 - "$p" "$d/.claude/settings.json" <<'PY' || { echo "hookprobe: could not write the scratch .claude/settings.json — INCONCLUSIVE (setup failed)"; exit 4; }
import json, sys, shlex
p, out = sys.argv[1], sys.argv[2]
q = shlex.quote(p)
def cmd(ev): return {"type": "command", "command": q + " " + ev}
settings = {"hooks": {
    "SessionStart": [{"hooks": [cmd("SessionStart")]}],
    "PreToolUse":  [{"matcher": "Bash", "hooks": [cmd("PreToolUse")]}],
    "PostToolUse": [{"matcher": "Bash", "hooks": [cmd("PostToolUse")]}],
    "Stop":        [{"hooks": [cmd("Stop")]}],
}}
with open(out, "w") as f:
    f.write(json.dumps(settings))
PY
  # Wall-clock cap (same pattern as the lanes: timeout/gtimeout, else a python3 process-group
  # cap) — a CLI hung on auth/network/sandbox must fail loud and bounded, not hang the verification.
  # Defined BEFORE the --version probe: an installed CLI that hangs during version discovery would
  # otherwise hang hookprobe forever (the cap must cover EVERY external CLI call, --version included).
  local cap="${PLINTH_HOOKPROBE_TIMEOUT:-120}" tmo=""
  command -v timeout >/dev/null 2>&1 && tmo="timeout"
  [ -z "$tmo" ] && command -v gtimeout >/dev/null 2>&1 && tmo="gtimeout"
  # HARD cap: timeout -k 10 escalates TERM->KILL after 10s; the python3 fallback (no coreutils)
  # runs the CLI in its own process group and TERM-then-KILLs it, so a signal-ignoring CLI cannot
  # wait forever. Exit 124 on timeout (mapped to INCONCLUSIVE by the caller).
  capped() {
    if [ -n "$tmo" ]; then "$tmo" -k 10 "$cap" "$@"
    else python3 -c 'import subprocess,sys,signal,os
cap=float(sys.argv[1]); p=subprocess.Popen(sys.argv[2:], preexec_fn=os.setsid)
try: sys.exit(p.wait(timeout=cap))
except subprocess.TimeoutExpired:
    g=os.getpgid(p.pid); os.killpg(g, signal.SIGTERM)
    try: p.wait(timeout=10)
    except subprocess.TimeoutExpired: os.killpg(g, signal.SIGKILL)
    sys.exit(124)' "$cap" "$@"; fi
  }
  # --version is capped too: a broken/unauthenticated CLI that hangs on version discovery must
  # fail bounded, not hang hookprobe forever. `head` closing the pipe early is fine; the cap
  # guarantees a bounded wait regardless of the CLI's behavior.
  ver="$(capped "$vendor" --version 2>/dev/null | head -1 || echo unknown)"
  [ -n "$ver" ] || ver=unknown
  # The probe command leaves a SENTINEL (cli-ran.txt): hooks only had a chance to fire
  # if the CLI actually executed a tool command. Without the sentinel the result is
  # INCONCLUSIVE (unauthenticated CLI, sandbox refusal, model failure, …), never
  # "executed NONE" — an empty marker from a broken run is not evidence of anything.
  # `|| vrc=$?`, not `; vrc=$?`: this script runs set -e, and a bare failing subshell
  # statement would abort the probe before the timeout/inconclusive branches report.
  case "$vendor" in
    grok)  ( cd "$d" && capped grok -p "Run this exact shell command: touch cli-ran.txt" \
               --permission-mode bypassPermissions --sandbox workspace --max-turns 3 ) >/dev/null 2>&1 || vrc=$? ;;
    codex) ( cd "$d" && printf 'Run this exact shell command: touch cli-ran.txt' \
               | capped codex exec --skip-git-repo-check --sandbox workspace-write - ) >/dev/null 2>&1 || vrc=$? ;;
  esac
  if [ "$vrc" = 124 ] || [ "$vrc" = 142 ] || [ "$vrc" = 137 ]; then
    echo "hookprobe: $vendor ($ver) TIMED OUT after ${cap}s — probe INCONCLUSIVE (auth/network/sandbox hang?). Nothing verified."
    exit 4
  fi
  if [ ! -f "$d/cli-ran.txt" ]; then
    echo "hookprobe: $vendor ($ver) FAILED to execute the probe command (CLI exit $vrc — unauthenticated? sandbox refused? model error?) — INCONCLUSIVE: this is NOT evidence about hook execution. Fix the CLI and re-run."
    exit 4
  fi
  if [ "$vrc" != 0 ]; then
    echo "hookprobe: $vendor ($ver) exited NONZERO ($vrc) after executing the probe command — INCONCLUSIVE: a late failure (finalization/teardown) could swallow late hook events such as Stop. Nothing verified; fix the CLI and re-run."
    exit 4
  fi
  # marker read/transform failure is INCONCLUSIVE, not evidence of NONE. An ABSENT marker is
  # legitimately "no events fired" (empty); a sort ERROR on a present marker is a broken probe.
  if [ -e "$marker" ]; then
    fired="$(sort -u "$marker")" || { echo "hookprobe: $vendor ($ver) — could not read the marker file — INCONCLUSIVE (broken probe). Re-run."; exit 4; }
  else fired=""; fi
  for ev in $evs; do
    if printf '%s\n' "$fired" | grep -qx "$ev"; then
      # invocation happened — did it come with parseable JSON on stdin (what the real
      # hooks need)? Reported per event; never treated as proof of enforcement.
      if jq -e . "$d/payload-$ev" >/dev/null 2>&1; then report="${report}${ev}: INVOKED(json-stdin:yes); "
      else report="${report}${ev}: INVOKED(json-stdin:no); "; fi
    else report="${report}${ev}: no; "; allfired=0; fi
  done
  if [ "$allfired" = 1 ]; then
    echo "hookprobe: $vendor ($ver) invoked ALL FOUR wired .claude/ hook events (${report% }) — NECESSARY for local enforcement but NOT SUFFICIENT: Plinth's real hooks also need Claude-shaped stdin JSON and CLAUDE_PROJECT_DIR. Verify END-TO-END before relying on local gates (wire the real hooks, run one session, confirm the pulse feed appears and a guard block fires). A missing pulse feed under an all-four driver means BROKEN WIRING."
    exit 0
  elif [ -z "$fired" ]; then
    echo "hookprobe: $vendor ($ver) executed NONE of the wired .claude/ hook events (${report% }) — nothing local is enforced: expect feedless watch and contract-bound review under this driver. Re-run after CLI upgrades."
    exit 1
  else
    echo "hookprobe: $vendor ($ver) invoked SOME hook events only (${report% }) — PARTIAL Claude-compat: a NOT-invoked event is certainly unenforced; an INVOKED event still needs end-to-end verification before you rely on it."
    exit 1
  fi
}

case "$cmd" in
  statusline) statusline_render ;;
  advise) run_advise "$@" ;;
  hookprobe) run_hookprobe "$@" ;;
  queue) run_queue ;;
  smoke) run_smoke "$@" ;;
  watch) watch_project ;;
  init)
    preflight_reserved_lanes
    copy_templates_if_absent
    copy_shared
    # Backfill security patterns even on init: a re-run (or a partially-scaffolded repo)
    # may already have a pre-v4.4 .plinth/protected-paths that copy_templates_if_absent
    # keeps as-is, so the new contract-file patterns (reviewer.md, CLAUDE.md, AGENTS.md)
    # would otherwise be missing. Idempotent — a fresh template already has them.
    ensure_protected_paths
    github_preflight
    warn_missing_gate_wiring
    echo "Plinth $PLINTH_VERSION initialized in $target"
    echo "Next: edit SPEC.md; commit. (ci.yml is zero-edit: owner auto-injected, checks auto-detect the stack at CI time.)"
    ;;
  update)
    [ -f "$target/.plinth-version" ] || { echo "Not a Plinth project (no .plinth-version). Run 'plinth init' first."; exit 1; }
    old="$(cat "$target/.plinth-version")"
    preflight_reserved_lanes
    copy_templates_if_absent
    copy_shared
    ensure_protected_paths
    migrate_needs_human
    # Tier-2 cross-vendor audit needs audit_vendor; init sets it but existing
    # configs are preserved, so remind upgraded projects (MANUAL.md points here).
    # The audit only runs when audit_vendor DIFFERS from the primary reviewer_vendor,
    # so suggest a different one than whatever this project's primary is.
    if ! grep -q '^audit_vendor' "$target/.plinth/config" 2>/dev/null; then
      rv="$(sed -n 's/^reviewer_vendor[[:space:]]*=[[:space:]]*//p' "$target/.plinth/config" 2>/dev/null | head -1)"
      [ -n "$rv" ] || rv=codex
      # v4 seats: the claude audit is the recommended second opinion (a different
      # family than both the grok driver and a codex/grok primary); a claude
      # PRIMARY can't audit itself, so it gets grok.
      case "$rv" in claude) sug=grok ;; *) sug=claude ;; esac
      # The suggested value is a SINGLE valid vendor (copy-pastable); agy is offered in
      # prose OUTSIDE the config line so it is never pasted as part of the value.
      # An unset audit_vendor DEFAULTS to codex in review.sh, so the audit is OFF only when
      # the primary is also codex; for a claude/grok primary the codex default already runs.
      if [ "$rv" = codex ]; then
        echo "  note: audit_vendor unset — it defaults to codex == reviewer_vendor (codex), so Tier 2 approvals get NO cross-vendor second opinion. Add 'audit_vendor = $sug' (or 'agy') to .plinth/config."
      else
        echo "  note: audit_vendor unset — it defaults to codex, which differs from reviewer_vendor ($rv), so the cross-vendor audit already runs with codex. Add 'audit_vendor = $sug' (or 'agy') to pin the auditor explicitly."
      fi
    fi
    github_preflight
    warn_missing_gate_wiring
    warn_stale_reusable_refs
    echo "Plinth updated in $target: $old -> $PLINTH_VERSION"
    echo "Review before committing: git -C \"$target\" diff"
    ;;
  goal)
    if [ -f "$target/GOAL.md" ]; then
      echo "GOAL.md already exists in $target — not overwriting."
      exit 1
    fi
    cp "$PLINTH_ROOT/templates/GOAL.template.md" "$target/GOAL.md"
    echo "GOAL.md draft created in $target."
    echo "Workflow: have the driver draft the specifics -> YOU ratify (STATUS: RATIFIED)"
    echo "-> add the eval script pattern to .plinth/protected-paths -> have Codex attack"
    echo "the rubric for gameability -> then let the loop run."
    ;;
  *) usage ;;
esac
