#!/usr/bin/env bash
# Plinth CLI v4.1.5 — scaffold and update projects from a pinned Plinth release.
#
#   plinth init   <project-path>  Bootstrap: create per-project files (only where
#                                 absent) + copy shared files. Idempotent.
#   plinth watch  <project-path>  Live session dashboard (task, stage pipeline,
#                                 tokens, burn, review/gate state). --once for a
#                                 single frame.
#   plinth update <project-path>  Propagate a Plinth version to an existing project:
#                                 refresh shared files (always overwritten), backfill
#                                 any per-project files new to this Plinth version
#                                 (created only if absent — yours are never touched),
#                                 report the version transition. Refuses to run on a
#                                 directory that isn't already a Plinth project.
#   plinth goal   <project-path>  Drop a GOAL.md draft (auto-research mode) if absent.
#
# Operates from the Plinth checkout it lives in. To adopt a new Plinth version:
# `git -C <plinth> pull` (or checkout a tag), then `plinth update <project>`.
set -euo pipefail

# Resolve symlinks so PLINTH_ROOT is the real checkout, not the symlink's dir.
# (A naive dirname "$BASH_SOURCE" resolves to /usr/local when invoked via the
#  /usr/local/bin/plinth symlink, breaking every subcommand. Do not simplify.)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"  # relative link -> absolute
done
PLINTH_ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
PLINTH_VERSION="$(cat "$PLINTH_ROOT/VERSION" 2>/dev/null || echo "unknown")"

usage() { echo "Usage: plinth {init|update|goal|watch|statusline|queue} <project-path> [--once]
       plinth smoke <project-path> -- <command...>   (run + write execution receipt)
       plinth queue <project-path>                   (full NEEDS-HUMAN queue, untruncated)"; exit 1; }
[ $# -ge 1 ] || usage
cmd="$1"; target="${2:-}"; opt="${3:-}"
if [ "$cmd" = "statusline" ]; then
  :  # project path optional — falls back to the statusLine JSON on stdin
elif [ -z "$target" ]; then
  usage
elif [ ! -d "$target" ]; then
  echo "No such directory: $target"; exit 1
fi

# Portable in-place edit (macOS + Linux): sed to temp file, then move.
edit_file() {  # edit_file <file> <sed-expr>...
  local f="$1"; shift
  local tmp="${f}.plinth-tmp"
  sed "$@" "$f" > "$tmp" && mv "$tmp" "$f"
}

# Detect the GitHub owner for ci.yml injection. Chain: target repo's origin ->
# this Plinth checkout's origin -> git config github.user -> empty (warn).
# Parses both git@github.com:owner/repo.git and https://github.com/owner/repo(.git).
detect_owner() {
  local url owner
  for repo in "$target" "$PLINTH_ROOT"; do
    url="$(git -C "$repo" remote get-url origin 2>/dev/null || true)"
    if [ -n "$url" ]; then
      owner="$(printf '%s' "$url" | sed -E 's#^(git@[^:]+:|https?://[^/]+/)([^/]+)/.*#\2#')"
      if [ -n "$owner" ] && [ "$owner" != "$url" ]; then printf '%s' "$owner"; return 0; fi
    fi
  done
  owner="$(git config github.user 2>/dev/null || true)"
  [ -n "$owner" ] && { printf '%s' "$owner"; return 0; }
  printf ''
}

# SHARED (version-pinned, overwritten on update):
copy_shared() {
  mkdir -p "$target/.plinth" "$target/.claude/hooks"
  cp "$PLINTH_ROOT/shared/plinth-rules.md"        "$target/.plinth/plinth-rules.md"
  cp "$PLINTH_ROOT/shared/MODELS.md"              "$target/.plinth/MODELS.md"
  cp "$PLINTH_ROOT/shared/.plinth/review.sh"      "$target/.plinth/review.sh"
  cp "$PLINTH_ROOT/shared/.plinth/review-schema.json" "$target/.plinth/review-schema.json"
  cp "$PLINTH_ROOT/shared/.claude/hooks/guard.sh" "$target/.claude/hooks/guard.sh"
  cp "$PLINTH_ROOT/shared/.claude/hooks/session-start.sh" "$target/.claude/hooks/session-start.sh"
  cp "$PLINTH_ROOT/shared/.claude/hooks/review-gate.sh"   "$target/.claude/hooks/review-gate.sh"
  cp "$PLINTH_ROOT/shared/.claude/hooks/pulse.sh"         "$target/.claude/hooks/pulse.sh"
  cp "$PLINTH_ROOT/shared/AGENTS.md"              "$target/AGENTS.md"
  chmod +x "$target/.plinth/review.sh" "$target/.claude/hooks/guard.sh" \
           "$target/.claude/hooks/session-start.sh" "$target/.claude/hooks/review-gate.sh" \
           "$target/.claude/hooks/pulse.sh"
  echo "$PLINTH_VERSION" > "$target/.plinth-version"
}

# GitHub preflight: verify the layers underneath the gates actually exist.
# Automates what is safe (local git init), asks consent for what is outward
# (creating a GitHub repo), and only REPORTS on branch protection — required-
# check names exist only after the first CI run; configuring them blind can
# block merging forever behind checks that never report.
github_preflight() {
  if ! git -C "$target" rev-parse --git-dir >/dev/null 2>&1; then
    git -C "$target" init -b main >/dev/null 2>&1 || git -C "$target" init >/dev/null 2>&1
    echo "  git:           initialized repository — Plinth's review, gates, and dashboard were inert without it"
  fi
  if ! git -C "$target" rev-parse -q --verify HEAD >/dev/null 2>&1; then
    echo "  git:           NO COMMITS yet — commit the scaffold + spec BEFORE starting a"
    echo "                 driver. Verdicts and gates bind to commits; on an unborn branch"
    echo "                 the review loop cannot run."
  fi
  command -v gh >/dev/null 2>&1 || { echo "  github:        gh CLI not found — install it to verify/create the remote and check protection"; return 0; }
  gh auth status >/dev/null 2>&1 || { echo "  github:        gh not authenticated (run: gh auth login) — skipping remote/protection checks"; return 0; }

  local url name slug defb out
  url="$(git -C "$target" remote get-url origin 2>/dev/null || true)"
  if [ -z "$url" ]; then
    name="$(basename "$target")"
    if [ -t 0 ]; then
      printf '  github:        no origin remote. Create GitHub repo "%s" now? [y/N] ' "$name"
      read -r ans || ans=""
      if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
        printf '  visibility:    public gets branch protection on the free plan; private needs Pro. [public/private] (public): '
        read -r vis || vis=""
        [ "$vis" = "private" ] || vis="public"
        if (cd "$target" && gh repo create "$name" "--$vis" --source . --push); then
          echo "  github:        created and pushed ($vis)"
          url="$(git -C "$target" remote get-url origin 2>/dev/null || true)"
        else
          echo "  github:        creation failed — run manually: gh repo create $name --$vis --source \"$target\" --push"
          return 0
        fi
      else
        echo "  github:        skipped. When ready: gh repo create $name --public --source \"$target\" --push"
        return 0
      fi
    else
      echo "  github:        no origin remote. When ready: gh repo create $name --public --source \"$target\" --push"
      return 0
    fi
  fi

  slug="$(printf '%s' "$url" | sed -E 's#^(git@[^:]+:|https?://[^/]+/)##; s#\.git$##')"
  defb="$(gh api "repos/$slug" -q .default_branch 2>/dev/null || echo main)"
  if out="$(gh api "repos/$slug/branches/$defb/protection" 2>&1)"; then
    echo "  protection:    configured on $defb"
  elif printf '%s' "$out" | grep -q "Upgrade to GitHub Pro"; then
    echo "  protection:    IMPOSSIBLE on this plan (private repo, GitHub Free) — floor/checks are"
    echo "                 NOT required to merge. Make the repo public or upgrade to Pro."
  elif printf '%s' "$out" | grep -qi "not protected"; then
    echo "  protection:    available but NOT configured on $defb. After the first PR shows the"
    echo "                 check names, require them: repo Settings -> Branches -> protect $defb."
  else
    echo "  protection:    could not determine: $(printf '%s' "$out" | tr '\n' ' ' | head -c 90)"
  fi
}

# settings.json is per-project (never overwritten), so new hook wiring cannot
# propagate silently. Warn when the shared hooks exist but aren't wired.
warn_missing_gate_wiring() {
  if ! grep -q 'review-gate.sh' "$target/.claude/settings.json" 2>/dev/null; then
    echo "NOTE: .claude/settings.json (yours, never overwritten) lacks the review-gate"
    echo "wiring — the review Stop gate is NOT enforced in this project. Add the"
    echo "SessionStart and Stop hook entries from CHANGELOG v3.7."
  fi
  if ! grep -q 'pulse.sh' "$target/.claude/settings.json" 2>/dev/null; then
    echo "NOTE: .claude/settings.json lacks pulse.sh wiring — 'plinth watch' will"
    echo "have no event feed for this project. See CHANGELOG v3.8."
  fi
}

# PER-PROJECT (templates, copied once, never overwritten):
copy_templates_if_absent() {
  place() {  # place <template-rel-path> <dest-rel-path>
    if [ -f "$target/$2" ]; then
      echo "  kept (yours):  $2"
    else
      cp "$PLINTH_ROOT/templates/$1" "$target/$2"
      echo "  created:       $2"
    fi
  }
  mkdir -p "$target/.claude" "$target/.github/workflows" "$target/.plinth"
  place CLAUDE.md CLAUDE.md
  place SPEC.md SPEC.md
  place .gitignore .gitignore
  place .claude/settings.json .claude/settings.json
  place AGENTS-project.md .plinth/AGENTS-project.md
  if [ -f "$target/.plinth/protected-paths" ]; then
    echo "  kept (yours):  .plinth/protected-paths"
  else
    printf '# One grep -E pattern per line; matching paths are agent-immutable.\n# Use (^|/)name anchoring, not ^name: agent file paths are often absolute.\n# Version-pinned Plinth tooling is immutable in-session; updates come via plinth update.\n(^|/)\\.plinth/session/\n(^|/)\\.plinth/config$\n(^|/)\\.claude/hooks/\n(^|/)\\.claude/settings\\.json$\n(^|/)\\.plinth/review\\.sh$\n(^|/)\\.plinth/review-schema\\.json$\n(^|/)\\.plinth/plinth-rules\\.md$\n(^|/)\\.plinth/MODELS\\.md$\n(^|/)\\.plinth/protected-paths$\n(^|/)AGENTS\\.md$\n' > "$target/.plinth/protected-paths"
    echo "  created:       .plinth/protected-paths"
  fi
  if [ -f "$target/.plinth/config" ]; then
    echo "  kept (yours):  .plinth/config"
  else
    printf '# Plinth per-project config. Never overwritten by plinth update.\n# Agent-immutable (protected-paths). Three knobs, all set-once:\n# spec_path: canonical spec — file (SPEC.md) or directory tree (spec/).\n# exec_gated: space-separated grep -E patterns for execution-gated paths;\n#   RUNTIME: review findings there route to the run gate instead of blocking.\n# smoke_cmd: the real-run command the Smoke workflow executes on the\n#   self-hosted runner (empty = smoke job no-ops green).\n# Everything else has working defaults.\nspec_path = SPEC.md\n' > "$target/.plinth/config"
    echo "  created:       .plinth/config"
  fi
  place .github/workflows/smoke.yml .github/workflows/smoke.yml
  if [ -f "$target/.github/workflows/ci.yml" ]; then
    echo "  kept (yours):  .github/workflows/ci.yml"
  else
    cp "$PLINTH_ROOT/templates/.github/workflows/ci.yml" "$target/.github/workflows/ci.yml"
    owner="$(detect_owner)"
    if [ -n "$owner" ]; then
      edit_file "$target/.github/workflows/ci.yml" -e "s|OWNER/plinth/|${owner}/plinth/|g"
      echo "  created:       .github/workflows/ci.yml (OWNER='$owner' auto-detected)"
    else
      echo "  created:       .github/workflows/ci.yml — WARNING: owner undetected, edit OWNER manually"
    fi
  fi
}

# NEEDS-HUMAN items are often multi-line markdown: emit one LOGICAL item per
# line (continuations joined), open ("- [ ]") items only, falling back to any
# non-blank content. Shared by watch and `plinth queue`.
open_items() {  # open_items <needs-human-file>
  awk '
    /^- \[ \]/ { if (cur != "") print cur; cur = substr($0, 7); next }
    /^- \[/    { if (cur != "") print cur; cur = ""; next }
    /^#/       { if (cur != "") print cur; cur = ""; next }
    cur != ""  { line = $0; gsub(/^[[:space:]]+|[[:space:]]+$/, "", line);
                 if (line != "") cur = cur " " line; next }
    END        { if (cur != "") print cur }
  ' "$1" 2>/dev/null
}

# Full queue, every item, folded to terminal width — the readable, scrollable
# home for long queues (the watch banner caps to what fits the screen).
run_queue() {
  local f="$target/.plinth/NEEDS-HUMAN.md"
  [ -s "$f" ] || { echo "plinth queue: nothing pending in $f"; exit 0; }
  local cols wrapw items
  cols="${PLINTH_WATCH_COLS:-$(tput cols 2>/dev/null || echo 100)}"
  [ "$cols" -ge 40 ] 2>/dev/null || cols=100
  wrapw=$((cols - 4))
  items="$(open_items "$f")"
  [ -n "$items" ] || items="$(grep -v '^[[:space:]]*$' "$f")"
  local qb; qb="$(printf '%s\n' "$items" | grep -c '^\[BLOCKING\]' || true)"
  echo "⏸ NEEDS-HUMAN — $target ($(printf '%s\n' "$items" | grep -c .) open, $qb blocking)"
  while IFS= read -r item; do
    [ -n "$item" ] || continue
    printf '%s\n' "· $item" | fold -s -w "$wrapw" | sed '2,$s/^/  /'
  done <<< "$items"
}

# ── plinth watch ──────────────────────────────────────────────────────────────
# Live session dashboard. Reads the raw event feed (.plinth/session/events.jsonl,
# written by pulse.sh) + the Claude Code transcript it points at + the review
# verdict, and renders task / stage pipeline / tokens / burn / gates every 2s.
# All interpretation lives here in one jq program — events stay raw facts.
render_frame() {
  local EV="$target/.plinth/session/events.jsonl"
  if [ ! -f "$EV" ]; then
    echo "plinth watch: no event feed at $EV"
    echo "Is pulse.sh wired in .claude/settings.json? (see CHANGELOG v3.8)"
    return 0
  fi
  local transcript head branch slug
  transcript="$(jq -rs '[.[] | select(.transcript != null)] | last | .transcript // empty' "$EV" 2>/dev/null)"
  [ -f "$transcript" ] || transcript=/dev/null
  head="$(git -C "$target" rev-parse --short HEAD 2>/dev/null || echo '-')"
  branch="$(git -C "$target" symbolic-ref --short -q HEAD 2>/dev/null || echo '-')"
  slug="$(printf '%s' "$branch" | tr '/ ' '--')"
  local vfile="$target/.plinth/session/review/$slug/verdict.json"; [ -f "$vfile" ] || vfile=/dev/null
  local ufile="$target/.plinth/session/review/$slug/usage.jsonl"; [ -f "$ufile" ] || ufile=/dev/null
  # A round in flight: the newest request-N.json outruns verdict.json.
  local rqfile
  rqfile="$(ls "$target/.plinth/session/review/$slug"/request-*.json 2>/dev/null | sort -t- -k2 -n | tail -1 || true)"
  [ -n "$rqfile" ] && [ -f "$rqfile" ] || rqfile=/dev/null
  local rfile="$target/.plinth/session/run/$slug/receipt.json"; [ -f "$rfile" ] || rfile=/dev/null
  local nh="" nhn=0 nhb=0
  if [ -s "$target/.plinth/NEEDS-HUMAN.md" ]; then
    # Open items = unchecked boxes; fall back to any non-blank line.
    # Full text, every item, SOFTWARE-WRAPPED to the terminal width with a
    # hanging indent: the in-place repaint assumes one logical line per
    # physical row, so we must never rely on the terminal to wrap.
    local raw cols wrapw item rows budget used=0 shown=0 folded flines
    raw="$(open_items "$target/.plinth/NEEDS-HUMAN.md")"
    [ -n "$raw" ] || raw="$(grep -v '^[[:space:]]*$' "$target/.plinth/NEEDS-HUMAN.md")"
    nhn="$(printf '%s\n' "$raw" | grep -c . || true)"
    nhb="$(printf '%s\n' "$raw" | grep -c '^\[BLOCKING\]' || true)"
    cols="${PLINTH_WATCH_COLS:-$(tput cols 2>/dev/null || echo 100)}"
    [ "$cols" -ge 40 ] 2>/dev/null || cols=100
    wrapw=$((cols - 6))
    # The frame must fit the screen or the repaint loses its top: show as many
    # COMPLETE items as fit, then point at `plinth queue` for the rest.
    rows="${PLINTH_WATCH_ROWS:-$(tput lines 2>/dev/null || echo 40)}"
    [ "$rows" -ge 24 ] 2>/dev/null || rows=40
    # Reserve = fixed frame (~19 rows incl. CI + banner header) + live footer.
    budget=$((rows - 21)); [ "$budget" -ge 3 ] || budget=3
    while IFS= read -r item; do
      [ -n "$item" ] || continue
      folded="$(printf '%s\n' "· $item" | fold -s -w "$wrapw" | sed '2,$s/^/  /')"
      flines="$(printf '%s\n' "$folded" | wc -l | tr -d ' ')"
      if [ $((used + flines)) -gt "$budget" ] && [ "$shown" -gt 0 ]; then break; fi
      nh+="$folded"$'\n'; used=$((used + flines)); shown=$((shown + 1))
      [ "$used" -ge "$budget" ] && break
    done <<< "$raw"
    if [ "$shown" -lt "$nhn" ]; then
      nh+="… +$((nhn - shown)) more — full queue: plinth queue $target"$'\n'
    fi
    nh="${nh%$'\n'}"
  fi

  # Live CI row once the feed shows a PR: pull the check rollup from GitHub.
  # PLINTH_CI_STATUS ('{"pass":N,"fail":N,"pending":N}') overrides for non-gh CIs.
  local ci="null"
  if [ -n "${PLINTH_CI_STATUS:-}" ]; then
    ci="$PLINTH_CI_STATUS"
  elif grep -qE 'gh pr (create|merge)' "$EV" 2>/dev/null && command -v gh >/dev/null 2>&1; then
    ci="$( (cd "$target" && gh pr view --json statusCheckRollup 2>/dev/null) | jq -c '
      {pass:    ([.statusCheckRollup[]? | select(.conclusion=="SUCCESS" or .state=="SUCCESS")] | length),
       fail:    ([.statusCheckRollup[]? | select(.conclusion=="FAILURE" or .conclusion=="ERROR" or .conclusion=="CANCELLED" or .state=="FAILURE" or .state=="ERROR")] | length),
       pending: ([.statusCheckRollup[]? | select(.status=="IN_PROGRESS" or .status=="QUEUED" or .status=="PENDING" or .state=="PENDING")] | length)}' 2>/dev/null)"
    [ -n "$ci" ] || ci="null"
  fi

  jq -rn --slurpfile ev "$EV" --slurpfile tr "$transcript" --slurpfile vd "$vfile" \
        --slurpfile us "$ufile" --slurpfile rc "$rfile" --slurpfile rq "$rqfile" \
        --arg nh "$nh" --argjson nhn "${nhn:-0}" --argjson nhb "${nhb:-0}" \
        --arg head "$head" --arg branch "$branch" --argjson ci "$ci" '
    # ---------- helpers ----------
    def B: "[1m";  def D: "[2m";  def R: "[0m";
    def CY: "[36m"; def GR: "[32m"; def YE: "[33m";
    def RD: "[31m"; def MG: "[35m"; def RV: "[7m";
    def rpad(n): (. + (" " * n))[0:n];
    def hum_t: if . == null or . < 0 then "—"
      elif . < 60 then "\(. | floor)s"
      elif . < 3600 then "\((. / 60) | floor)m \((. % 60) | floor)s"
      else "\((. / 3600) | floor)h \(((. % 3600) / 60) | floor)m" end;
    def hum_k: if . == null then "—"
      elif . >= 1000000 then "\(. / 1000000 * 10 | floor / 10)M"
      elif . >= 1000 then "\(. / 1000 * 10 | floor / 10)k"
      else "\(.)" end;
    def ago($now): ($now - .) | hum_t + " ago";

    ($ev | map(select(type == "object"))) as $all
    | (now | floor) as $NOW
    # focus: the most recently ACTIVE session — not the last SessionStart;
    # sessions that predate their own wiring have no start event (certeus bug)
    | (([$all[] | select(.sid != null)] | .[-1].sid)) as $sid
    | ($all | map(select(.sid == $sid))) as $sev
    | if ($sev | length) == 0 then "plinth watch: event feed has no session events yet." else

    ($sev[0].epoch) as $t0
    # ---------- stage classification (facts -> stages, renderer-side only) ----------
    | def stage_of:
        if .event == "PostToolUse" and (.tool == "Edit" or .tool == "Write" or .tool == "MultiEdit" or .tool == "NotebookEdit")
        then "IMPLEMENT"
        elif .event == "PostToolUse" and .tool == "Bash" then
          ((.detail // "") |
            if test("review\\.sh") then "REVIEW"
            elif test("gh pr (create|merge)") then "PR"
            elif test("(^|[;&|(\\s])(pytest|go test|cargo (test|nextest|check)|npm (test|run test)|yarn test|pnpm test|python3? -m (pytest|unittest)|make (test|check)|mix test|rspec|jest|vitest|tox|swift test)")
            then "VERIFY" else null end)
        else null end;
    ([{e: $t0, s: "PLAN"}] + [$sev[] | (stage_of) as $s | select($s != null) | {e: .epoch, s: $s}]) as $marks
    # collapse consecutive same-stage marks, then close segments
    | ($marks | reduce .[] as $m ([]; if ((.[-1].s) // "") == $m.s then . else . + [$m] end)) as $tx
    | [range(0; $tx | length) | {s: $tx[.].s, a: $tx[.].e, b: (if . + 1 < ($tx | length) then $tx[. + 1].e else $NOW end)}] as $segs
    | ($segs[-1].s) as $cur
    # ---------- tokens from the transcript ----------
    | ($tr | map(select(type == "object" and .type == "assistant" and (.message.usage? != null))
        | {e: ((.timestamp // "") | sub("\\.[0-9]+Z$"; "Z") | try fromdate catch null),
           i: (.message.usage.input_tokens // 0), cc: (.message.usage.cache_creation_input_tokens // 0),
           cr: (.message.usage.cache_read_input_tokens // 0), o: (.message.usage.output_tokens // 0),
           m: (.message.model // null)}
        | select(.e != null))) as $use
    | {i: ($use | map(.i) | add // 0), cc: ($use | map(.cc) | add // 0),
       cr: ($use | map(.cr) | add // 0), o: ($use | map(.o) | add // 0)} as $tot
    | ([$segs | group_by(.s)[] | {s: .[0].s,
         t: (map(.b - .a) | add),
         k: (map(. as $g | [$use[] | select(.e >= $g.a and .e < $g.b) | .i + .cc + .o] | add // 0) | add)}]) as $per
    | ([$use[] | select(.e > $NOW - 300) | .i + .cc + .o] | add // 0) as $last5
    # sparkline: 12 one-minute buckets
    | (["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]) as $bars
    | ([range(0; 12) | . as $b | [$use[] | select(.e > $NOW - (12 - $b) * 60 and .e <= $NOW - (11 - $b) * 60) | .i + .cc + .o] | add // 0]) as $bkt
    | (($bkt | max) // 0) as $bmax
    | ($bkt | map(if $bmax == 0 then "▁" else $bars[(. / $bmax * 7) | floor] end) | join("")) as $spark
    # ---------- signals ----------
    | ([$all[] | select(.event == "guard_block" and .epoch >= $t0)] | length) as $blocks
    | ([$all[] | select(.event == "gate_release" and .epoch >= $t0)] | length) as $releases
    | ([$sev[] | select(.event == "PreCompact")] | length) as $compacts
    | ([$sev[] | select(.event == "SubagentStop")] | length) as $subs
    | (([$sev[] | select(.event == "UserPromptSubmit") | .detail // ""
         | select((test("^\\s*<") | not) and length > 0)] | .[-1]) // "(no prompt recorded)") as $task
    | ([$sev[] | select((stage_of) == "VERIFY")] | .[-1]) as $evd
    | ([$sev[] | select(.event == "PostToolUse")] | .[-1]) as $lastact
    | (($use | map(.m) | map(select(. != null)) | .[-1]) // "—") as $model
    | ($vd[0] // null) as $V
    # ---------- frame ----------
    | (["PLAN", "IMPLEMENT", "VERIFY", "REVIEW", "PR"]) as $ORDER
    | ([ $ORDER[] | . as $s | ($per | map(select(.s == $s)) | .[0]) as $p
        | if $p == null then D + "   " + ($s | rpad(10)) + ("—" | rpad(10)) + "—" + R
          elif $s == $cur then RV + B + " ▶ " + ($s | rpad(10)) + (($p.t | hum_t) | rpad(10)) + (($p.k | hum_k) + " tok")
               + "  · now " + ((($NOW - $segs[-1].a) | hum_t)) + R
          else GR + " ✓ " + R + ($s | rpad(10)) + (($p.t | hum_t) | rpad(10)) + D + (($p.k | hum_k) + " tok") + R
          end ] | join("\n")) as $pipe0
    | ($pipe0 + "\n" + D + " Σ TOTAL    " + ((($per | map(.t) | add) // 0 | hum_t) | rpad(10))
        + ((($per | map(.k) | add) // 0 | hum_k) + " tok") + R) as $pipe0
    | ($pipe0 + (if $ci == null then "" else "\n"
        + (if ($ci.fail // 0) > 0 then RD elif ($ci.pending // 0) > 0 then YE else GR end)
        + "   CI        " + "✓\($ci.pass // 0)  ✗\($ci.fail // 0)  ◌\($ci.pending // 0)" + R end)) as $pipe
    | (($rq[0] // null) as $RQ
       | if $RQ != null and ($RQ.round // 0) > (($V.round // 0)) then
           YE + "round \($RQ.round) RUNNING (\($RQ.mode))" + R
           + (($RQ.ts // "" | sub("\\.[0-9]+Z$"; "Z") | try fromdate catch null) as $rs
              | if $rs != null then D + " · " + (($NOW - $rs) | hum_t) + " in" + R else "" end)
           + D + " · last verdict: " + ($V.verdict // "none") + " r\($V.round // 0)" + R
         else null end) as $running
    | (if $running != null then $running
       elif $V == null then D + "no review round yet — ./.plinth/review.sh" + R
       else ((if $V.verdict == "APPROVED" then GR else YE end) + $V.verdict + R
         + D + " · round " + ($V.round | tostring) + " @ " + ($V.sha[0:7]) + R
         + (if ($V.sha[0:7]) == $head then GR + " = HEAD ✓" + R else RD + " ≠ HEAD " + $head + " — stale, re-run review" + R end)
         + (if $V.usage then D + " · reviewer " + ($V.usage.input_tokens | hum_k) + " in / " + ($V.usage.output_tokens | hum_k) + " out" + R else "" end)
         + (($us | map(.usage.input_tokens // 0) | add // 0) as $rtot
            | if $rtot > 0 then D + " · Σ " + ($rtot | hum_k) + " in" + R else "" end)
         + (if $V.audit then (if ($V.audit.blocking // 0) > 0 then RD + " · AUDIT DISAGREES (\($V.audit.blocking))" + R else D + " · audit ✓" + R end) else "" end))
       end) as $review
    | (if ($rc | length) == 0 then D + "no run receipt — RUNTIME findings await plinth smoke" + R
       else ($rc[0]) as $R
         | (if ($R.exit // 1) == 0 then GR + "exit 0" + R else RD + "exit \($R.exit)" + R end)
           + D + " · " + (($R.cmd // "?")[0:44]) + " · " + (($R.ended // $NOW) | ago($NOW)) + " @ " + (($R.sha // "")[0:7]) + R
       end) as $runline
    | (if $evd == null then D + "no test runner seen this session" + R
       else ($evd.detail[0:56])
         + (if $evd.rc == 0 then GR + " → exit 0" + R
            elif $evd.rc != null then RD + " → exit \($evd.rc)" + R
            else D + " → ran" + R end)
         + D + " · " + ($evd.epoch | ago($NOW)) + R
       end) as $evidence
    | (if $lastact == null then D + "—" + R
       else ($lastact.tool // "?") + D + " " + (($lastact.detail // "")[0:56]) + " · " + ($lastact.epoch | ago($NOW)) + R end) as $nowline

    | B + CY + " ◤ PLINTH WATCH " + R + B + ($task[0:58]) + R + "\n"
    + D + "   " + $branch + " @ " + $head + " · " + $model + " · session " + (($NOW - $t0) | hum_t) + R + "\n"
    + D + " ─────────────────────────────────────────────────────────────────" + R + "\n"
    + $pipe + "\n"
    + D + " ─────────────────────────────────────────────────────────────────" + R + "\n"
    + B + " tokens   " + R + (($tot.i + $tot.cc + $tot.cr + $tot.o) | hum_k)
      + D + "  (in " + ($tot.i | hum_k) + " · cache-write " + ($tot.cc | hum_k) + " · cache-read " + ($tot.cr | hum_k) + " · out " + ($tot.o | hum_k) + ")" + R + "\n"
    + B + " burn     " + R + (($last5 / 5 | floor) | hum_k) + "/min  " + MG + $spark + R + D + "  (last 12 min, fresh+out)" + R + "\n"
    + B + " review   " + R + $review + "\n"
    + B + " run      " + R + $runline + "\n"
    + B + " evidence " + R + $evidence + "\n"
    + B + " signals  " + R
      + (if $blocks > 0 then RD + "guard blocks \($blocks)" + R else D + "guard blocks 0" + R end)
      + (if $releases > 0 then RD + " · GATE RELEASES \($releases) — unreviewed work escaped the session gate" + R
         else D + " · gate releases 0" + R end)
      + D + " · compactions \($compacts) · subagent runs \($subs)" + R + "\n"
    + B + " now      " + R + $nowline
    # Variable-height content lives at the BOTTOM: the fixed dashboard keeps a
    # stable screen position; the queue grows downward where it displaces nothing.
    + (if $nh != "" then
         "\n" + D + " ─────────────────────────────────────────────────────────────────" + R + "\n"
         + RD + RV + " ⏸ NEEDS HUMAN (\($nhn) open\(if $nhb > 0 then " · \($nhb) BLOCKING" else "" end)) " + R + "\n"
         + ([$nh | split("\n")[] | select(length > 0) | RD + "   " + . + R] | join("\n"))
       else "" end)
    end
  ' 2>/dev/null || echo "plinth watch: render error (malformed event or transcript line?)"
}

# Execution evidence: run a real command and write a SHA-bound receipt the
# review loop consumes (RUNTIME findings get verified against observation,
# not guesses). Failures are data — the receipt records them the same way.
run_smoke() {
  shift 2   # drop 'smoke' <path>
  [ "${1:-}" = "--" ] && shift
  [ $# -ge 1 ] || usage
  local br rslug rdir ts log start end rc=0
  br="$(git -C "$target" symbolic-ref --short -q HEAD 2>/dev/null || echo detached)"
  rslug="$(printf '%s' "$br" | tr '/ ' '--')"
  rdir="$target/.plinth/session/run/$rslug"
  mkdir -p "$rdir"
  [ -f "$target/.plinth/session/.gitignore" ] || printf '*\n' > "$target/.plinth/session/.gitignore"
  ts="$(date -u +%Y%m%dT%H%M%SZ)"; log="$rdir/smoke-$ts.log"
  echo "plinth smoke [$br]: $*"
  start="$(date +%s)"
  ( cd "$target" && "$@" ) 2>&1 | tee "$log" || rc=$?
  end="$(date +%s)"
  jq -n --arg sha "$(git -C "$target" rev-parse HEAD 2>/dev/null || echo none)" \
        --arg branch "$br" --arg cmd "$*" --argjson exit "${rc:-0}" \
        --argjson started "$start" --argjson ended "$end" \
        --arg hw "$(uname -m) · $(sysctl -n machdep.cpu.brand_string 2>/dev/null || uname -s)" \
        --arg log "$log" --arg tail "$(tail -n 40 "$log" 2>/dev/null)" \
        '{sha: $sha, branch: $branch, cmd: $cmd, exit: $exit, started: $started, ended: $ended,
          secs: ($ended - $started), hw: $hw, log: $log, log_tail: $tail}' \
        > "$rdir/receipt.json"
  echo "plinth smoke: exit ${rc:-0} in $((end - start))s · receipt: $rdir/receipt.json"
  exit "${rc:-0}"
}

# One-line renderer for Claude Code's statusLine setting. Reads the statusLine
# JSON on stdin (workspace dir), or takes an explicit project path. Consults
# only the event feed + verdict — no transcript parse, cheap at statusline
# cadence. Token economics stay on `plinth watch`.
statusline_render() {
  local in dir
  in="$(cat 2>/dev/null || true)"
  dir="$target"
  [ -n "$dir" ] || dir="$(printf '%s' "$in" | jq -r '.workspace.current_dir // .cwd // empty' 2>/dev/null)"
  { [ -n "$dir" ] && [ -d "$dir" ]; } || exit 0
  local EV="$dir/.plinth/session/events.jsonl"
  [ -f "$EV" ] || { printf 'plinth: no session feed'; exit 0; }
  local head vfile
  head="$(git -C "$dir" rev-parse --short HEAD 2>/dev/null || echo '-')"
  local sslug nh=""
  sslug="$(git -C "$dir" symbolic-ref --short -q HEAD 2>/dev/null | tr '/ ' '--')"
  vfile="$dir/.plinth/session/review/${sslug:-detached}/verdict.json"; [ -f "$vfile" ] || vfile=/dev/null
  local nhblk=""
  if [ -s "$dir/.plinth/NEEDS-HUMAN.md" ]; then
    nh="$(grep -cE '^- \[ \]' "$dir/.plinth/NEEDS-HUMAN.md" 2>/dev/null || echo 1)"
    nhblk="$(grep -cE '^- \[ \] \[BLOCKING\]' "$dir/.plinth/NEEDS-HUMAN.md" 2>/dev/null || true)"
    [ "$nhblk" != "0" ] && [ -n "$nhblk" ] && nh="${nh}⛔${nhblk}"
  fi
  jq -rn --slurpfile ev "$EV" --slurpfile vd "$vfile" --arg head "$head" --arg nh "$nh" '
    def hum_t: if . < 60 then "\(. | floor)s" elif . < 3600 then "\((. / 60) | floor)m"
      else "\((. / 3600) | floor)h\(((. % 3600) / 60) | floor)m" end;
    ($ev | map(select(type == "object"))) as $all
    | (now | floor) as $NOW
    | (([$all[] | select(.sid != null)] | .[-1].sid)) as $sid
    | ($all | map(select(.sid == $sid))) as $sev
    | if ($sev | length) == 0 then "plinth: no session" else
      ($sev[0].epoch) as $t0
      | def stage_of:
          if .event == "PostToolUse" and (.tool == "Edit" or .tool == "Write" or .tool == "MultiEdit" or .tool == "NotebookEdit")
          then "IMPLEMENT"
          elif .event == "PostToolUse" and .tool == "Bash" then
            ((.detail // "") |
              if test("review\\.sh") then "REVIEW"
              elif test("gh pr (create|merge)") then "PR"
              elif test("(^|[;&|(\\s])(pytest|go test|cargo (test|nextest|check)|npm (test|run test)|yarn test|pnpm test|python3? -m (pytest|unittest)|make (test|check)|mix test|rspec|jest|vitest|tox|swift test)")
              then "VERIFY" else null end)
          else null end;
      (([{e: $t0, s: "PLAN"}] + [$sev[] | (stage_of) as $s | select($s != null) | {e: .epoch, s: $s}])
        | reduce .[] as $m ([]; if ((.[-1].s) // "") == $m.s then . else . + [$m] end) | .[-1]) as $cur
      | ($vd[0] // null) as $V
      | (if $V == null then "no review"
         elif $V.verdict == "APPROVED" and ($V.sha[0:7]) == $head then "APPROVED ✓"
         elif $V.verdict == "APPROVED" then "APPROVED (stale)"
         else "CHANGES r\($V.round)" end) as $rv
      | ([$all[] | select(.event == "guard_block" and .epoch >= $t0)] | length) as $b
      | ([$all[] | select(.event == "gate_release" and .epoch >= $t0)] | length) as $r
      | "◆ " + $cur.s + " " + (($NOW - $cur.e) | hum_t) + " · " + $rv
        + (if $nh != "" and $nh != "0" then " · ⏸ HUMAN×" + $nh else "" end)
        + (if $b > 0 then " · guard⛔\($b)" else "" end)
        + (if $r > 0 then " · RELEASED \($r)" else "" end)
      end'
}

# Inside $(render_frame) tput talks to a pipe and reports 24×80 regardless of
# the real window, starving the queue budget. Read the size from the TTY and
# hand it down via the PLINTH_WATCH_* overrides (honoring any the user set).
capture_tty_size() {
  local _sz
  if _sz="$(stty size </dev/tty 2>/dev/null)"; then
    [ -n "${PLINTH_WATCH_ROWS_USER:-}" ] || export PLINTH_WATCH_ROWS="${_sz% *}"
    [ -n "${PLINTH_WATCH_COLS_USER:-}" ] || export PLINTH_WATCH_COLS="${_sz#* }"
  fi
}

watch_project() {
  # User-provided sizes win permanently; otherwise track the TTY per repaint.
  [ -n "${PLINTH_WATCH_ROWS:-}" ] && export PLINTH_WATCH_ROWS_USER=1
  [ -n "${PLINTH_WATCH_COLS:-}" ] && export PLINTH_WATCH_COLS_USER=1
  if [ "$opt" = "--once" ]; then capture_tty_size; render_frame; exit 0; fi
  local EV="$target/.plinth/session/events.jsonl"
  local wslug VD
  wslug="$(git -C "$target" symbolic-ref --short -q HEAD 2>/dev/null | tr '/ ' '--')"
  VD="$target/.plinth/session/review/${wslug:-detached}/verdict.json"
  # mtime+size stamp, BSD then GNU stat.
  fstamp() { stat -f '%m %z' "$1" 2>/dev/null || stat -c '%Y %s' "$1" 2>/dev/null || echo 0; }
  # Alt screen + hidden cursor; restore on exit. Clear once at startup only.
  printf '\033[?1049h\033[?25l\033[2J'
  trap 'printf "\033[?25h\033[?1049l"; exit 0' INT TERM
  local last="" beat=10 stamp frame
  while :; do
    # Cheap 1s poll on file stamps; re-render (jq over feed + transcript) only
    # on change, plus a 10s heartbeat so elapsed/ago clocks stay live.
    stamp="$(fstamp "$EV") $(fstamp "$VD")"
    if [ "$stamp" != "$last" ] || [ "$beat" -ge 10 ]; then
      last="$stamp"; beat=0
      capture_tty_size   # per repaint: window resizes tracked
      # Repaint in place: home cursor, overwrite each line erasing its tail
      # (ESC[K), then erase below the frame (ESC[J). No full clear, no blink.
      frame="$(render_frame; printf '\n\033[2m  live — repaints on activity (1s poll, 10s heartbeat) · ctrl-c to quit\033[0m')"
      printf '\033[H'
      printf '%s\n' "$frame" | sed $'s/$/\033[K/'
      printf '\033[J'
    fi
    beat=$((beat + 1))
    sleep 1
  done
}

case "$cmd" in
  statusline) statusline_render ;;
  queue) run_queue ;;
  smoke) run_smoke "$@" ;;
  watch) watch_project ;;
  init)
    copy_templates_if_absent
    copy_shared
    github_preflight
    warn_missing_gate_wiring
    echo "Plinth $PLINTH_VERSION initialized in $target"
    echo "Next: edit SPEC.md; commit. (ci.yml is zero-edit: owner auto-injected, checks auto-detect the stack at CI time.)"
    ;;
  update)
    [ -f "$target/.plinth-version" ] || { echo "Not a Plinth project (no .plinth-version). Run 'plinth init' first."; exit 1; }
    old="$(cat "$target/.plinth-version")"
    copy_templates_if_absent
    copy_shared
    github_preflight
    warn_missing_gate_wiring
    echo "Plinth updated in $target: $old -> $PLINTH_VERSION"
    echo "Review before committing: git -C \"$target\" diff"
    ;;
  goal)
    if [ -f "$target/GOAL.md" ]; then
      echo "GOAL.md already exists in $target — not overwriting."
      exit 1
    fi
    cp "$PLINTH_ROOT/templates/GOAL.template.md" "$target/GOAL.md"
    echo "GOAL.md draft created in $target."
    echo "Workflow: have the driver draft the specifics -> YOU ratify (STATUS: RATIFIED)"
    echo "-> add the eval script pattern to .plinth/protected-paths -> have Codex attack"
    echo "the rubric for gameability -> then let the loop run."
    ;;
  *) usage ;;
esac
